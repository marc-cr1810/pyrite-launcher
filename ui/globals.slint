// Shared data structures and the themeable design tokens.
//
// `Theme` is the single source of truth for colors. Every component reads from
// it, and Rust overrides its properties at startup from a JSON palette
// (built-in default or a user theme). See `src/app/theme.rs`.

export struct AccountItem {
    uuid: string,
    username: string,
    kind: string,      // "Microsoft" or "Offline"
    active: bool,
    initial: string,       // first letter, for the monogram avatar
    avatar-color: color,   // stable color derived from the account
    avatar: image,         // player head (empty until fetched); monogram shows meanwhile
}

export struct InstanceItem {
    id: string,
    name: string,
    version: string,
    loader: string,    // "" for vanilla, otherwise "Fabric"/"Forge"/"NeoForge"
    active: bool,
    initial: string,       // first letter, for the monogram avatar
    avatar-color: color,   // stable color derived from the instance
    // Icon: raw id ("" / builtin id / "custom"), the glyph to show for built-in
    // icons (empty otherwise), and the custom image (empty unless "custom").
    icon-id: string,
    icon-glyph: string,
    icon-image: image,
    // Per-instance launch overrides (empty string = unset), for the edit dialog
    jvm-args: string,
    java-path: string,
    pre-launch: string,
    post-exit: string,
    // Playtime stats
    last-played: string,   // human-readable relative time ("2 hours ago", "Never")
    playtime: string,      // human-readable duration ("2h 15m", "< 1m", "—")
}

// One selectable built-in icon in the picker grid.
export struct IconOption {
    id: string,
    glyph: string,
}

// A Minecraft world (save) inside an instance's `saves/` dir.
export struct WorldItem {
    folder-name: string,
    last-played: string,
    size: string,          // pre-formatted human size
    icon: image,           // saves/<world>/icon.png, empty if none
}

// One styled run of text from a Minecraft `§`-formatted string.
export struct FmtSpan {
    text: string,
    color: color,
    bold: bool,
    italic: bool,
}

// One line of a formatted description (a run of styled spans).
export struct FmtLine {
    spans: [FmtSpan],
}

// A resource pack or shader pack file/dir. `display-name` strips ".disabled".
export struct AssetItem {
    filename: string,      // on-disk name (may end in ".disabled")
    display-name: string,
    size: string,
    enabled: bool,
    description: string,   // plain text (codes stripped); "" => show size
    desc-lines: [FmtLine], // colored render of the description
    icon: image,           // the pack's pack.png, empty if none
}

// A screenshot, with a decoded thumbnail.
export struct ScreenshotItem {
    filename: string,
    created: string,
    size: string,
    image: image,
}

// A full-instance backup zip (saves + config + options.txt).
export struct BackupItem {
    filename: string,
    created: string,       // parsed from the backup_<timestamp>.zip name
    size: string,
}

// An installed mod jar with parsed metadata.
export struct ModItem {
    filename: string,      // on-disk name (may end in ".disabled")
    name: string,
    version: string,
    description: string,   // plain text (codes stripped); "" => no description
    desc-lines: [FmtLine], // colored render of the description
    enabled: bool,
}

export struct VersionItem {
    id: string,
    kind: string,      // "release" / "snapshot" / loader version
}

// One Modrinth search result (modpack / mod / resource pack / shader).
export struct ModrinthHit {
    project-id: string,
    slug: string,
    title: string,
    description: string,
    author: string,
    downloads: string,   // pre-formatted ("1.2M")
    icon: image,         // decoded thumbnail, empty until fetched
}

// Full project detail (gallery, body, versions, links) shown after clicking a hit.
export struct ModrinthDetail {
    project-id: string,
    kind: string,        // mod / modpack / resourcepack / shader
    title: string,
    author: string,
    description: string, // short summary
    body: string,        // simplified plain-text of the Markdown body
    icon: image,
    downloads: string,
    updated: string,     // human-relative ("3 days ago")
    categories: string,  // comma-joined
    source-url: string,
    issues-url: string,
    wiki-url: string,
    discord-url: string,
    page-url: string,    // modrinth.com project page
    gallery: [image],    // decoded gallery images, fill in as they arrive
    // Parallel arrays: picker labels and the version ids they map to.
    version-labels: [string],
    version-ids: [string],
}

export struct JavaRuntimeItem {
    major: int,
    name: string,
    description: string,
    status: string,
    is-active: bool,
}

export struct LogLine {
    text: string,
    level: string,     // "error" / "warn" / "info" / "plain"
}

export global Theme {
    // Surfaces
    in property <color> window-bg: #16161e;
    in property <color> sidebar-bg: #13131a;
    in property <color> surface: #1f1f2e;
    in property <color> surface-alt: #262636;
    in property <color> surface-hover: #2e2e42;
    // Text
    in property <color> text: #e6e6f0;
    in property <color> text-muted: #a9a9c2;
    in property <color> text-dim: #6c6c85;
    // Accent
    in property <color> accent: #7aa2f7;
    in property <color> accent-hover: #8fb3ff;
    in property <color> accent-text: #0d0d14;
    // Lines / status
    in property <color> border: #2c2c3e;
    in property <color> success: #9ece6a;
    in property <color> warning: #e0af68;
    in property <color> error: #f7768e;

    // Geometry tokens (not themed via JSON for now)
    out property <length> radius: 10px;
    out property <length> radius-sm: 6px;
    out property <length> gap: 12px;
    out property <length> pad: 16px;
}

// Single bridge between the UI and Rust: shared state (properties Rust pushes
// into the UI) and callbacks (events the UI sends to Rust). Wired in main.rs.
export global Logic {
    // --- Accounts ---
    in property <[AccountItem]> accounts;
    callback select-account(string /* uuid */);
    callback remove-account(string /* uuid */);
    callback add-offline(string /* username */);
    // Microsoft device-code login dialog
    in property <bool> ms-active;
    in-out property <bool> ms-dialog-open;
    in property <string> ms-user-code;
    in property <string> ms-verification-uri;
    in property <string> ms-message;
    callback start-microsoft();
    callback cancel-microsoft();
    callback open-url(string);
    callback copy-code(string);

    // --- Instances ---
    in property <[InstanceItem]> instances;
    callback select-instance(string /* id */);
    callback delete-instance(string /* id */);
    callback duplicate-instance(string /* id */);
    // name, game-version, loader ("" = vanilla), loader-version ("" = auto),
    // icon-id ("" / builtin id / "custom"), memory-mb ("" = default), jvm-args
    callback create-instance(string, string, string, string, string, string, string);
    // id, name, jvm-args, java-path, pre-launch, post-exit, icon-id
    callback edit-instance(string, string, string, string, string, string, string);
    // Instance sorting ("name" / "last-played" / "playtime")
    in-out property <string> instance-sort: "name";
    callback sort-instances(string /* sort-key */);
    // Instance search/filter
    in-out property <string> instance-search;
    callback search-instances(string /* query */);
    // Version picker data for the create dialog (plain strings for ComboBox)
    in property <[string]> version-list;
    in property <bool> versions-loading;
    callback load-versions();
    // Re-derive version-list from the cached manifest for a type filter:
    // "release" / "snapshot" / "old_beta" / "old_alpha".
    callback filter-versions(string /* type */);
    in property <[string]> loader-version-list;
    in property <bool> loader-versions-loading;
    callback load-loader-versions(string /* loader */, string /* game-version */);

    // --- Instance content management (detail pane tabs) ---
    // Which instance the lists below belong to (so stale data isn't shown).
    in property <string> detail-id;
    in property <[WorldItem]> inst-worlds;
    in property <[AssetItem]> inst-resourcepacks;
    in property <[AssetItem]> inst-shaderpacks;
    in property <[ScreenshotItem]> inst-screenshots;
    in property <[ModItem]> inst-mods;
    in property <[BackupItem]> inst-backups;
    in property <bool> inst-supports-mods;     // instance has a mod loader
    in property <bool> inst-supports-shaders;  // a shader loader (Iris/OptiFine) is present
    // Load (or reload) every list above for the given instance.
    callback load-instance-details(string /* id */);
    // Open a subdir of the instance in the system file manager.
    callback open-instance-dir(string /* id */, string /* subdir */);
    // Native multi-file picker; copies into the kind's subdir.
    callback add-files(string /* id */, string /* kind: resourcepacks|shaderpacks|mods */);
    callback delete-world(string /* id */, string /* folder */);
    callback backup-world(string /* id */, string /* folder */);
    callback toggle-resourcepack(string /* id */, string /* filename */);
    callback delete-resourcepack(string /* id */, string /* filename */);
    callback toggle-shaderpack(string /* id */, string /* filename */);
    callback delete-shaderpack(string /* id */, string /* filename */);
    callback toggle-mod(string /* id */, string /* filename */, bool /* enable */);
    callback remove-mod(string /* id */, string /* filename */);
    callback delete-screenshot(string /* id */, string /* filename */);
    callback create-backup(string /* id */);
    callback restore-backup(string /* id */, string /* filename */);
    callback delete-backup(string /* id */, string /* filename */);

    // --- Modrinth browse (shared by the Modrinth view + in-detail dialogs) ---
    in property <[ModrinthHit]> modrinth-results;
    in property <bool> modrinth-loading;
    in property <string> modrinth-status;     // inline status / error / empty messaging
    in property <bool> modrinth-can-load-more; // more results available beyond what's shown
    in property <bool> modrinth-loading-more;  // a "load more" page is in flight
    callback modrinth-load-more();
    // kind: "modpack" | "mod" | "resourcepack" | "shader". instance-id is "" for
    // modpacks (no version/loader filter); otherwise the search is scoped to it.
    callback modrinth-search(string /* query */, string /* kind */, string /* instance-id */);
    // Install a browsed mod/pack into an existing instance. version-id "" = latest compatible.
    callback modrinth-install(string /* instance-id */, string /* project-id */, string /* kind */, string /* version-id */);
    // Create a new instance from a modpack: project-id, chosen name, icon-id
    // ("" / builtin id / "custom" / "modpack" for the pack's own icon), memory-mb,
    // jvm-args, version-id ("" = latest).
    callback modrinth-create-instance(string, string, string, string, string, string);
    // Project detail view (gallery, body, versions, links).
    in property <ModrinthDetail> modrinth-detail;
    in property <bool> modrinth-detail-loading;
    in property <bool> modrinth-detail-open;
    callback modrinth-open-detail(string /* project-id */, string /* kind */);
    callback modrinth-close-detail();
    // Import a local .mrpack file as a new instance (opens a native file picker).
    callback import-mrpack();
    // Export an existing instance to a .mrpack (opens a native save dialog).
    callback export-mrpack(string /* id */);

    // --- Instance icon picker (shared by create + edit; one is open at a time) ---
    in property <[IconOption]> icon-options;       // built-in grid, set at startup
    in-out property <string> pending-icon-id;      // "" / builtin id / "custom"
    in-out property <string> pending-icon-glyph;   // glyph for the selected built-in
    in-out property <image> pending-icon-image;    // preview for a custom png
    callback pick-custom-icon();                   // opens native file dialog
    callback reset-pending-icon-file();            // clears a stale picked-file path

    // --- Active selection summary (Play view) ---
    in property <string> active-account-name;
    in property <string> active-account-initial;
    in property <color> active-account-color;
    in property <image> active-account-avatar;
    in property <string> active-instance-name;
    in property <string> active-instance-initial;
    in property <color> active-instance-color;
    in property <string> active-instance-version;
    in property <string> active-instance-loader;
    in property <string> active-instance-glyph;   // built-in icon glyph, or ""
    in property <image> active-instance-image;     // custom icon, or empty
    in property <bool> can-play;

    // --- Launch / progress / logs ---
    in property <bool> is-busy;
    in property <bool> game-running; // the game process is live (vs. preparing)
    in property <string> status-text;
    in property <bool> progress-active;
    in property <bool> progress-indeterminate; // animated sweep for phases with no measurable progress
    in property <float> progress-value;     // 0..1
    in property <[LogLine]> log-lines;
    callback play();
    callback clear-logs();
    callback copy-logs();

    // --- Settings & theming ---
    in-out property <string> game-dir;
    in-out property <string> java-path;
    in-out property <string> jvm-args;
    in property <[string]> themes;
    in-out property <string> active-theme;
    in property <[JavaRuntimeItem]> java-runtimes;
    in property <bool> java-installing;
    callback save-settings(string /* game-dir */, string /* java-path */, string /* jvm-args */);
    callback select-theme(string);
    callback install-java(int /* major version */);
    callback use-java-runtime(int /* major */);

    // --- Crash diagnostics ---
    in-out property <bool> show-crash-dialog: false;
    in-out property <string> crash-title;
    in-out property <string> crash-description;
    in-out property <[string]> crash-solutions;
}
