import { Theme, Logic, Lightbox } from "globals.slint";
import { Avatar, Dialog, PButton } from "components.slint";
import { PlayView } from "views/play.slint";
import { AccountsView } from "views/accounts.slint";
import { InstancesView } from "views/instances.slint";
import { ModrinthView } from "views/modrinth.slint";
import { SettingsView } from "views/settings.slint";

// Re-export so Rust's generated bindings expose these globals/structs.
export { Theme, Logic }
export { AccountItem, InstanceItem, VersionItem, LogLine, IconOption } from "globals.slint";
export { WorldItem, AssetItem, ScreenshotItem, ModItem, FmtSpan, FmtLine, BackupItem, ModrinthHit } from "globals.slint";
export { ModrinthDetail } from "globals.slint";

component NavItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> selected;
    callback clicked();
    height: 44px;
    border-radius: Theme.radius-sm;
    background: selected ? Theme.surface-alt : (touch.has-hover ? Theme.surface : transparent);
    animate background { duration: 100ms; }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;
        Text {
            text: root.icon;
            font-size: 16px;
            vertical-alignment: center;
            color: root.selected ? Theme.accent : Theme.text-muted;
        }
        Text {
            text: root.label;
            font-size: 14px;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;
            color: root.selected ? Theme.text : Theme.text-muted;
        }
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component MainWindow inherits Window {
    title: "Pyrite Launcher";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 860px;
    min-height: 560px;
    background: Theme.window-bg;

    property <int> current-view: 0;

    HorizontalLayout {
        // Sidebar
        Rectangle {
            width: 220px;
            background: Theme.sidebar-bg;
            VerticalLayout {
                padding: 16px;
                spacing: 6px;
                HorizontalLayout {
                    padding-bottom: 16px;
                    spacing: 10px;
                    Text { text: "◆"; color: Theme.accent; font-size: 22px; vertical-alignment: center; }
                    Text { text: "Pyrite"; color: Theme.text; font-size: 20px; font-weight: 800; vertical-alignment: center; }
                }
                NavItem { label: "Play"; icon: "▶"; selected: root.current-view == 0; clicked => { root.current-view = 0; } }
                NavItem { label: "Instances"; icon: "▤"; selected: root.current-view == 1; clicked => { root.current-view = 1; } }
                NavItem { label: "Accounts"; icon: "◴"; selected: root.current-view == 2; clicked => { root.current-view = 2; } }
                NavItem { label: "Modrinth"; icon: "◈"; selected: root.current-view == 4; clicked => { root.current-view = 4; } }
                Rectangle { vertical-stretch: 1; }
                NavItem { label: "Settings"; icon: "⚙"; selected: root.current-view == 3; clicked => { root.current-view = 3; } }
                // Active account footer
                Rectangle {
                    height: 1px;
                    background: Theme.border;
                }
                Text {
                    text: Logic.active-account-name == "" ? "Not signed in" : Logic.active-account-name;
                    color: Theme.text-muted;
                    font-size: 12px;
                    overflow: elide;
                }
            }
        }

        // Content
        Rectangle {
            background: Theme.window-bg;
            VerticalLayout {
                // Header strip: current view title + persistent account chip.
                Rectangle {
                    height: 60px;
                    background: Theme.window-bg;
                    HorizontalLayout {
                        padding-left: 24px;
                        padding-right: 24px;
                        spacing: 12px;
                        Text {
                            text: root.current-view == 0 ? "Play"
                                : root.current-view == 1 ? "Instances"
                                : root.current-view == 2 ? "Accounts"
                                : root.current-view == 4 ? "Modrinth"
                                : "Settings";
                            color: Theme.text;
                            font-size: 22px;
                            font-weight: 700;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        if Logic.game-running : Text {
                            text: "● playing";
                            color: Theme.success;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        if Logic.is-busy && !Logic.game-running : Text {
                            text: "● working…";
                            color: Theme.warning;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        // Account chip
                        HorizontalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                alignment: center;
                                Avatar {
                                    initial: Logic.active-account-name == "" ? "?" : Logic.active-account-initial;
                                    tint: Logic.active-account-name == "" ? Theme.text-dim : Logic.active-account-color;
                                    size: 30px;
                                    photo: Logic.active-account-avatar;
                                }
                            }
                            Text {
                                text: Logic.active-account-name == "" ? "Not signed in" : Logic.active-account-name;
                                color: Theme.text-muted;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: Theme.border;
                    }
                }
                Rectangle {
                    if root.current-view == 0 : PlayView { }
                    if root.current-view == 1 : InstancesView { }
                    if root.current-view == 2 : AccountsView { }
                    if root.current-view == 3 : SettingsView { }
                    if root.current-view == 4 : ModrinthView { }
                }
            }
        }
    }

    // Full-screen image viewer (screenshots, gallery images). Click the backdrop
    // or press Escape to dismiss; clicking the image itself does not close.
    if Lightbox.open : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000e0;

        backdrop := TouchArea {
            clicked => { Lightbox.close(); }
        }
        lb-keys := FocusScope {
            key-pressed(event) => {
                if event.text == Key.Escape {
                    Lightbox.close();
                    return accept;
                }
                return reject;
            }
        }
        init => { lb-keys.focus(); }

        VerticalLayout {
            padding: 40px;
            spacing: 14px;
            Image {
                vertical-stretch: 1;
                source: Lightbox.image;
                image-fit: contain;
                // Swallow clicks so the image area doesn't dismiss the viewer.
                TouchArea { mouse-cursor: default; }
            }
            if Lightbox.caption != "" : Text {
                text: Lightbox.caption;
                color: Theme.text;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }

        // Close affordance, top-right.
        Rectangle {
            x: parent.width - self.width - 24px;
            y: 24px;
            width: 40px;
            height: 40px;
            border-radius: Theme.radius-sm;
            background: close-touch.has-hover ? Theme.surface-hover : Theme.surface-alt;
            border-width: 1px;
            border-color: Theme.border;
            Text { text: "✕"; color: Theme.text; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
            close-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { Lightbox.close(); }
            }
        }
    }

    if Logic.show-crash-dialog : Dialog {
        dialog-width: 500px;
        closed => { Logic.show-crash-dialog = false; }
        Text { text: Logic.crash-title; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: Logic.crash-description;
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        Text { text: "Possible Solutions:"; color: Theme.text; font-size: 14px; font-weight: 600; }
        for sol in Logic.crash-solutions : HorizontalLayout {
            spacing: 6px;
            Text { text: "•"; color: Theme.accent; font-size: 13px; }
            Text { text: sol; color: Theme.text-muted; font-size: 13px; wrap: word-wrap; }
        }
        HorizontalLayout {
            alignment: end;
            padding-top: 8px;
            PButton { text: "Close"; primary: true; clicked => { Logic.show-crash-dialog = false; } }
        }
    }
}
