import { Theme, Logic, Lightbox, InstanceItem, AssetItem, WorldItem, ScreenshotItem, ModItem, FmtLine } from "../globals.slint";
import { Card, PButton, Avatar, LoaderBadge, EmptyState, Dialog, IconPicker } from "../components.slint";
import { ModrinthRow, ModrinthDetailPane } from "modrinth.slint";
import { ScrollView, LineEdit, ComboBox, Slider } from "std-widgets.slint";

// One tab in the detail-pane tab bar, with an underline accent when active.
component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked();
    height: 34px;
    horizontal-stretch: 0;
    min-width: t.preferred-width + 22px;
    border-radius: Theme.radius-sm;
    background: root.selected ? Theme.surface-alt : (touch.has-hover ? Theme.surface-hover : transparent);
    animate background { duration: 100ms; }
    t := Text {
        text: root.text;
        vertical-alignment: center;
        horizontal-alignment: center;
        color: root.selected ? Theme.text : Theme.text-muted;
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
    }
    Rectangle {
        y: parent.height - 2px;
        height: 2px;
        background: root.selected ? Theme.accent : transparent;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Renders a Minecraft `§`-formatted description: one HorizontalLayout row per
// line, each a run of individually-colored Text spans.
component FormattedText inherits VerticalLayout {
    in property <[FmtLine]> lines;
    for line in root.lines : HorizontalLayout {
        alignment: start;
        for span in line.spans : Text {
            text: span.text;
            color: span.color;
            font-size: 11px;
            font-weight: span.bold ? 700 : 400;
            font-italic: span.italic;
            vertical-alignment: center;
        }
    }
}

// A list section shared by Resource Packs and Shaders: an Add/Open header, then
// rows with an enable/disable toggle and delete. Emits filename-keyed actions.
component AssetSection inherits VerticalLayout {
    in property <[AssetItem]> model;
    in property <string> empty-title;
    callback add();
    callback browse();
    callback openf();
    callback toggle(string /* filename */);
    callback remove(string /* filename */, string /* display-name */);
    spacing: 10px;

    HorizontalLayout {
        spacing: 8px;
        Rectangle { horizontal-stretch: 1; }
        PButton { text: "Browse Modrinth"; primary: true; clicked => { root.browse(); } }
        PButton { text: "+ Add…"; clicked => { root.add(); } }
        PButton { text: "Open folder"; clicked => { root.openf(); } }
    }
    if root.model.length == 0 : EmptyState {
        vertical-stretch: 1;
        icon: "▦";
        title: root.empty-title;
        subtitle: "Add a file, or open the folder to drop one in.";
    }
    if root.model.length > 0 : ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 6px;
            for a in root.model : Rectangle {
                height: 72px;
                border-radius: Theme.radius-sm;
                background: Theme.surface-alt;
                clip: true;
                HorizontalLayout {
                    padding: 10px;
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface;
                            clip: true;
                            Text { width: 100%; height: 100%; text: "▦"; horizontal-alignment: center; vertical-alignment: center; color: Theme.text-dim; font-size: 18px; }
                            Image { width: 100%; height: 100%; source: a.icon; image-fit: contain; }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        spacing: 2px;
                        Text { text: a.display-name; color: a.enabled ? Theme.text : Theme.text-dim; font-size: 14px; font-weight: 600; overflow: elide; }
                        if a.description == "" : Text { text: a.size; color: Theme.text-muted; font-size: 11px; overflow: elide; }
                        if a.description != "" : FormattedText { lines: a.desc-lines; }
                    }
                    VerticalLayout {
                        alignment: center;
                        PButton { text: a.enabled ? "Disable" : "Enable"; clicked => { root.toggle(a.filename); } }
                    }
                    VerticalLayout {
                        alignment: center;
                        PButton { text: "Delete"; danger: true; clicked => { root.remove(a.filename, a.display-name); } }
                    }
                }
            }
        }
    }
}

export component InstancesView inherits Rectangle {
    property <bool> dialog-open: false;
    property <bool> confirm-open: false;
    // Detail-pane tab: 0 Settings, 1 Worlds, 2 Resource Packs, 3 Shaders,
    // 4 Mods, 5 Screenshots, 6 Backups.
    property <int> detail-tab: 0;
    // World pending deletion (saves are precious, so deletion is confirmed).
    property <bool> world-confirm-open: false;
    property <string> pending-world;
    // Backup pending restore (overwrites saves/config, so it is confirmed).
    property <bool> backup-confirm-open: false;
    property <string> pending-backup;
    property <string> pending-backup-date;
    // Mod deletion confirmation properties
    property <bool> mod-confirm-open: false;
    property <string> pending-mod-filename;
    property <string> pending-mod-name;
    // Resource pack/Shader pack deletion confirmation properties
    property <bool> pack-confirm-open: false;
    property <string> pending-pack-filename;
    property <string> pending-pack-name;
    property <string> pending-pack-type;
    // Modrinth browse dialog (mods / resource packs / shaders) for the open instance.
    property <bool> browse-open: false;
    property <string> browse-kind;   // "mod" | "resourcepack" | "shader"
    property <string> browse-title;
    // Change version/loader dialog for the selected instance.
    property <bool> version-dialog-open: false;
    property <string> ver-loader: "Vanilla";  // currently-chosen loader in that dialog
    property <[string]> loaders: ["Vanilla", "Fabric", "Forge", "NeoForge"];
    // Empty image, used as the "no custom photo" fallback for avatars.
    property <image> no-image;

    // Which instance the detail/edit pane is showing ("" = nothing selected).
    property <string> selected-id;
    // Snapshot of the selected instance's display identity (avatar/version/loader).
    property <string> sel-version;
    property <string> sel-loader;
    property <string> sel-initial;
    property <color> sel-color;
    property <bool> sel-active;
    // Snapshot of the selected instance's icon, so the picker can be re-seeded
    // after the (shared-state) create dialog closes.
    property <string> sel-icon-id;
    property <string> sel-icon-glyph;
    property <image> sel-icon-image;
    // Editable fields, seeded from the selected instance on selection.
    property <string> edit-name;
    property <int> edit-memory-mb;
    property <string> edit-jvm-args;
    property <string> edit-java-path;
    property <string> edit-pre-launch;
    property <string> edit-post-exit;

    // Point the shared icon picker at the currently selected instance.
    function seed-pending-from-selection() {
        Logic.pending-icon-id = root.sel-icon-id;
        Logic.pending-icon-glyph = root.sel-icon-glyph;
        Logic.pending-icon-image = root.sel-icon-image;
        Logic.reset-pending-icon-file();
    }

    // Restore the picker after the create dialog (which borrows the same shared
    // state) closes: back to the edit selection, or cleared if none.
    function restore-icon-picker() {
        if root.selected-id != "" {
            root.seed-pending-from-selection();
        } else {
            Logic.pending-icon-id = "";
            Logic.pending-icon-glyph = "";
            Logic.reset-pending-icon-file();
        }
    }

    // Seed the detail pane (and icon picker) from a list row.
    function select-row(inst: InstanceItem) {
        root.selected-id = inst.id;
        root.sel-version = inst.version;
        root.sel-loader = inst.loader;
        root.sel-initial = inst.initial;
        root.sel-color = inst.avatar-color;
        root.sel-active = inst.active;
        root.sel-icon-id = inst.icon-id;
        root.sel-icon-glyph = inst.icon-glyph;
        root.sel-icon-image = inst.icon-image;
        root.edit-name = inst.name;
        root.edit-memory-mb = inst.memory-mb;
        root.edit-jvm-args = inst.jvm-args;
        root.edit-java-path = inst.java-path;
        root.edit-pre-launch = inst.pre-launch;
        root.edit-post-exit = inst.post-exit;
        root.detail-tab = 0;
        root.seed-pending-from-selection();
        Logic.load-instance-details(inst.id);
    }

    // Open the Modrinth browse dialog scoped to the selected instance.
    function open-browse(kind: string, title: string) {
        root.browse-kind = kind;
        root.browse-title = title;
        root.browse-open = true;
        Logic.modrinth-close-detail();
        Logic.modrinth-search("", kind, root.selected-id);
    }

    HorizontalLayout {
        padding: 24px;
        spacing: 18px;

        // ---- Left: instance list ----
        VerticalLayout {
            width: 320px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 8px;
                PButton {
                    text: "+ New Instance";
                    primary: true;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.pending-icon-id = "";
                        Logic.pending-icon-glyph = "";
                        Logic.reset-pending-icon-file();
                        root.dialog-open = true;
                        Logic.load-versions();
                    }
                }
                PButton {
                    text: "Import .mrpack";
                    clicked => { Logic.import-mrpack(); }
                }
            }

            // Search + sort controls
            HorizontalLayout {
                spacing: 8px;
                search-edit := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "Search instances…";
                    text <=> Logic.instance-search;
                    edited(text) => { Logic.search-instances(text); }
                }
                sort-combo := ComboBox {
                    width: 120px;
                    model: ["Name", "Last Played", "Playtime"];
                    current-index: 0;
                    selected(val) => {
                        Logic.sort-instances(
                            val == "Last Played" ? "last-played"
                            : val == "Playtime" ? "playtime"
                            : "name");
                    }
                }
            }

            Card {
                vertical-stretch: 1;
                if Logic.instances.length == 0 : EmptyState {
                    icon: "▤";
                    title: "No instances yet";
                    subtitle: "Create one to choose a Minecraft version and mod loader.";
                }
                if Logic.instances.length > 0 : ScrollView {
                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        for inst in Logic.instances : Rectangle {
                            height: 76px;
                            clip: true;
                            border-radius: Theme.radius-sm;
                            background: inst.id == root.selected-id
                                ? Theme.surface-alt
                                : (row-touch.has-hover ? Theme.surface-hover : transparent);
                            border-width: 1px;
                            border-color: inst.id == root.selected-id ? Theme.accent : transparent;
                            animate background { duration: 100ms; }
                            HorizontalLayout {
                                padding: 10px;
                                spacing: 10px;
                                VerticalLayout {
                                    alignment: center;
                                    Avatar {
                                        initial: inst.icon-glyph != "" ? inst.icon-glyph : inst.initial;
                                        tint: inst.avatar-color;
                                        size: 38px;
                                        selected: inst.active;
                                        photo: inst.icon-image;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 3px;
                                    horizontal-stretch: 1;
                                    Text { text: inst.name; color: Theme.text; font-size: 15px; font-weight: 600; overflow: elide; }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: inst.version; color: Theme.text-muted; font-size: 11px; vertical-alignment: center; }
                                        if inst.loader != "" : LoaderBadge { loader: inst.loader; }
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text { text: "▸ " + inst.last-played; color: Theme.text-dim; font-size: 10px; }
                                        Text { text: "⏱ " + inst.playtime; color: Theme.text-dim; font-size: 10px; }
                                    }
                                }
                                if inst.active : VerticalLayout {
                                    alignment: center;
                                    Text { text: "●"; color: Theme.success; font-size: 11px; }
                                }
                            }
                            row-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.select-row(inst); }
                            }
                        }
                    }
                }
            }
        }

        // ---- Right: detail / edit pane ----
        Card {
            horizontal-stretch: 1;
            vertical-stretch: 1;

            if root.selected-id == "" : EmptyState {
                icon: "✎";
                title: "Select an instance";
                subtitle: "Pick an instance on the left to view and edit its settings.";
            }

            if root.selected-id != "" : VerticalLayout {
                padding: 24px;
                spacing: 14px;

                // Header: avatar (live icon) + name + version/loader.
                HorizontalLayout {
                    spacing: 14px;
                    VerticalLayout {
                        alignment: center;
                        Avatar {
                            initial: Logic.pending-icon-glyph != "" ? Logic.pending-icon-glyph : root.sel-initial;
                            tint: root.sel-color;
                            size: 52px;
                            selected: root.sel-active;
                            photo: Logic.pending-icon-id == "custom" ? Logic.pending-icon-image : root.no-image;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 4px;
                        horizontal-stretch: 1;
                        Text { text: root.edit-name; color: Theme.text; font-size: 20px; font-weight: 700; overflow: elide; }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text { text: root.sel-version; color: Theme.text-muted; font-size: 13px; vertical-alignment: center; }
                            if root.sel-loader != "" : LoaderBadge { loader: root.sel-loader; }
                            if root.sel-active : Text { text: "● active"; color: Theme.success; font-size: 12px; vertical-alignment: center; }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        PButton {
                            text: root.sel-active ? "Active" : "Use";
                            primary: !root.sel-active;
                            enabled: !root.sel-active;
                            clicked => {
                                Logic.select-instance(root.selected-id);
                                root.sel-active = true;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Tab bar. Shaders/Mods are hidden when not applicable.
                HorizontalLayout {
                    spacing: 4px;
                    TabButton { text: "Settings"; selected: root.detail-tab == 0; clicked => { root.detail-tab = 0; } }
                    TabButton { text: "Worlds"; selected: root.detail-tab == 1; clicked => { root.detail-tab = 1; } }
                    TabButton { text: "Resource Packs"; selected: root.detail-tab == 2; clicked => { root.detail-tab = 2; } }
                    if Logic.inst-supports-shaders : TabButton { text: "Shaders"; selected: root.detail-tab == 3; clicked => { root.detail-tab = 3; } }
                    if Logic.inst-supports-mods : TabButton { text: "Mods"; selected: root.detail-tab == 4; clicked => { root.detail-tab = 4; } }
                    TabButton { text: "Screenshots"; selected: root.detail-tab == 5; clicked => { root.detail-tab = 5; } }
                    TabButton { text: "Backups"; selected: root.detail-tab == 6; clicked => { root.detail-tab = 6; } }
                    Rectangle { horizontal-stretch: 1; }
                }

                // ---- Settings tab ----
                if root.detail-tab == 0 : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 14px;

                        IconPicker {
                            derived-initial: root.sel-initial;
                            derived-color: root.sel-color;
                        }

                        Text { text: "Name"; color: Theme.text-muted; font-size: 12px; }
                        name-edit := LineEdit { text <=> root.edit-name; placeholder-text: "My instance"; }

                        Text {
                            text: round(mem-slider.value) == 0
                                ? "Max memory: default"
                                : "Max memory: \{round(mem-slider.value)} MB (\{round(mem-slider.value / 1024 * 10) / 10} GB)";
                            color: Theme.text-muted; font-size: 12px;
                        }
                        mem-slider := Slider {
                            minimum: 0;
                            maximum: Logic.system-ram-mb;
                            value: root.edit-memory-mb;
                        }
                        if Logic.system-ram-mb > 0 : Text {
                            text: "Detected RAM: \{round(Logic.system-ram-mb / 1024 * 10) / 10} GB. 0 = launcher default.";
                            color: Theme.text-dim; font-size: 11px;
                        }

                        Text { text: "JVM arguments"; color: Theme.text-muted; font-size: 12px; }
                        jvm-edit := LineEdit { text <=> root.edit-jvm-args; placeholder-text: "-XX:+UseG1GC"; }

                        Text { text: "Java path"; color: Theme.text-muted; font-size: 12px; }
                        java-edit := LineEdit { text <=> root.edit-java-path; placeholder-text: "Leave blank to use the default Java"; }

                        Text { text: "Pre-launch command"; color: Theme.text-muted; font-size: 12px; }
                        pre-edit := LineEdit { text <=> root.edit-pre-launch; placeholder-text: "Optional command run before launch"; }

                        Text { text: "Post-exit command"; color: Theme.text-muted; font-size: 12px; }
                        post-edit := LineEdit { text <=> root.edit-post-exit; placeholder-text: "Optional command run after the game exits"; }

                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                spacing: 2px;
                                Text { text: "Minecraft version / mod loader"; color: Theme.text-muted; font-size: 12px; }
                                Text {
                                    text: root.sel-version + (root.sel-loader == "" ? "" : "  •  " + root.sel-loader);
                                    color: Theme.text; font-size: 13px; font-weight: 600;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                PButton {
                                    text: "Change…";
                                    clicked => {
                                        root.ver-loader = root.sel-loader == "" ? "Vanilla"
                                            : (root.sel-loader == "fabric" ? "Fabric"
                                            : root.sel-loader == "neoforge" ? "NeoForge"
                                            : root.sel-loader == "forge" ? "Forge" : "Vanilla");
                                        root.version-dialog-open = true;
                                        Logic.load-versions();
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            padding-top: 4px;
                            PButton { text: "Delete"; danger: true; clicked => { root.confirm-open = true; } }
                            PButton { text: "Duplicate"; clicked => { Logic.duplicate-instance(root.selected-id); } }
                            PButton { text: "Export .mrpack"; clicked => { Logic.export-mrpack(root.selected-id); } }
                            Rectangle { horizontal-stretch: 1; }
                            PButton {
                                text: "Save changes";
                                primary: true;
                                enabled: root.edit-name != "";
                                clicked => {
                                    Logic.edit-instance(
                                        root.selected-id,
                                        root.edit-name,
                                        round(mem-slider.value),
                                        root.edit-jvm-args,
                                        root.edit-java-path,
                                        root.edit-pre-launch,
                                        root.edit-post-exit,
                                        Logic.pending-icon-id);
                                }
                            }
                        }
                    }
                }

                // ---- Worlds tab ----
                if root.detail-tab == 1 : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        PButton { text: "Open folder"; clicked => { Logic.open-instance-dir(root.selected-id, "saves"); } }
                    }
                    if Logic.inst-worlds.length == 0 : EmptyState {
                        vertical-stretch: 1;
                        icon: "◳"; title: "No worlds yet";
                        subtitle: "Worlds you create or import in-game appear here.";
                    }
                    if Logic.inst-worlds.length > 0 : ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 6px;
                            for w in Logic.inst-worlds : Rectangle {
                                height: 68px;
                                border-radius: Theme.radius-sm;
                                background: Theme.surface-alt;
                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 48px;
                                            height: 48px;
                                            border-radius: Theme.radius-sm;
                                            background: Theme.surface;
                                            clip: true;
                                            Text { width: 100%; height: 100%; text: "◳"; horizontal-alignment: center; vertical-alignment: center; color: Theme.text-dim; font-size: 22px; }
                                            Image { width: 100%; height: 100%; source: w.icon; image-fit: cover; }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text { text: w.folder-name; color: Theme.text; font-size: 14px; font-weight: 600; overflow: elide; }
                                        Text { text: "Last played " + w.last-played + " · " + w.size; color: Theme.text-muted; font-size: 11px; }
                                    }
                                    VerticalLayout { alignment: center; PButton { text: "Backup"; clicked => { Logic.backup-world(root.selected-id, w.folder-name); } } }
                                    VerticalLayout { alignment: center; PButton { text: "Delete"; danger: true; clicked => { root.pending-world = w.folder-name; root.world-confirm-open = true; } } }
                                }
                            }
                        }
                    }
                }

                // ---- Resource Packs tab ----
                if root.detail-tab == 2 : AssetSection {
                    vertical-stretch: 1;
                    model: Logic.inst-resourcepacks;
                    empty-title: "No resource packs";
                    add => { Logic.add-files(root.selected-id, "resourcepacks"); }
                    browse => { root.open-browse("resourcepack", "resource packs"); }
                    openf => { Logic.open-instance-dir(root.selected-id, "resourcepacks"); }
                    toggle(f) => { Logic.toggle-resourcepack(root.selected-id, f); }
                    remove(f, name) => {
                        root.pending-pack-filename = f;
                        root.pending-pack-name = name;
                        root.pending-pack-type = "resourcepack";
                        root.pack-confirm-open = true;
                    }
                }

                // ---- Shaders tab ----
                if root.detail-tab == 3 : AssetSection {
                    vertical-stretch: 1;
                    model: Logic.inst-shaderpacks;
                    empty-title: "No shader packs";
                    add => { Logic.add-files(root.selected-id, "shaderpacks"); }
                    browse => { root.open-browse("shader", "shaders"); }
                    openf => { Logic.open-instance-dir(root.selected-id, "shaderpacks"); }
                    toggle(f) => { Logic.toggle-shaderpack(root.selected-id, f); }
                    remove(f, name) => {
                        root.pending-pack-filename = f;
                        root.pending-pack-name = name;
                        root.pending-pack-type = "shaderpack";
                        root.pack-confirm-open = true;
                    }
                }

                // ---- Mods tab ----
                if root.detail-tab == 4 : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        PButton {
                            text: Logic.mod-updates-checking ? "Checking…" : "Check for updates";
                            enabled: !Logic.mod-updates-checking;
                            clicked => { Logic.check-mod-updates(root.selected-id); }
                        }
                        if Logic.mod-update-count > 0 : PButton {
                            text: "Update all (" + Logic.mod-update-count + ")"; primary: true;
                            clicked => { Logic.update-all-mods(root.selected-id); }
                        }
                        PButton { text: "Browse Modrinth"; clicked => { root.open-browse("mod", "mods"); } }
                        PButton { text: "+ Add…"; clicked => { Logic.add-files(root.selected-id, "mods"); } }
                        PButton { text: "Open folder"; clicked => { Logic.open-instance-dir(root.selected-id, "mods"); } }
                    }
                    if Logic.inst-mods.length == 0 : EmptyState {
                        vertical-stretch: 1;
                        icon: "⬡"; title: "No mods installed";
                        subtitle: "Add mod jars, or open the folder to drop some in.";
                    }
                    if Logic.inst-mods.length > 0 : ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 6px;
                            for m in Logic.inst-mods : Rectangle {
                                height: 72px;
                                border-radius: Theme.radius-sm;
                                background: Theme.surface-alt;
                                clip: true;
                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text { text: m.name; color: m.enabled ? Theme.text : Theme.text-dim; font-size: 14px; font-weight: 600; overflow: elide; }
                                        if m.description != "" : FormattedText { lines: m.desc-lines; }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        width: 130px;
                                        spacing: 2px;
                                        Text { text: m.version; color: Theme.text-dim; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                                        if m.update-available : Text {
                                            text: "→ " + m.latest-version; color: Theme.success; font-size: 11px;
                                            horizontal-alignment: right; overflow: elide;
                                        }
                                    }
                                    if m.update-available : VerticalLayout {
                                        alignment: center;
                                        PButton { text: "Update"; primary: true; clicked => { Logic.update-mod(root.selected-id, m.filename); } }
                                    }
                                    VerticalLayout { alignment: center; PButton { text: m.enabled ? "Disable" : "Enable"; clicked => { Logic.toggle-mod(root.selected-id, m.filename, !m.enabled); } } }
                                    VerticalLayout { alignment: center; PButton { text: "Remove"; danger: true; clicked => { root.pending-mod-filename = m.filename; root.pending-mod-name = m.name; root.mod-confirm-open = true; } } }
                                }
                            }
                        }
                    }
                }

                // ---- Screenshots tab ----
                if root.detail-tab == 5 : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        PButton { text: "Open folder"; clicked => { Logic.open-instance-dir(root.selected-id, "screenshots"); } }
                    }
                    if Logic.inst-screenshots.length == 0 : EmptyState {
                        vertical-stretch: 1;
                        icon: "▱"; title: "No screenshots";
                        subtitle: "Screenshots you take in-game appear here.";
                    }
                    if Logic.inst-screenshots.length > 0 : ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 8px;
                            for s[idx] in Logic.inst-screenshots : Rectangle {
                                height: 84px;
                                border-radius: Theme.radius-sm;
                                background: Theme.surface-alt;
                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 12px;
                                    Rectangle {
                                        width: 110px;
                                        clip: true;
                                        Image { width: 100%; height: 100%; source: s.image; image-fit: contain; }
                                        shot-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { Lightbox.show(Logic.inst-screenshot-images, Logic.inst-screenshot-captions, idx); }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 3px;
                                        Text { text: s.filename; color: Theme.text; font-size: 13px; font-weight: 600; overflow: elide; }
                                        Text { text: s.created + " · " + s.size; color: Theme.text-muted; font-size: 11px; }
                                    }
                                    VerticalLayout { alignment: center; PButton { text: "Delete"; danger: true; clicked => { Logic.delete-screenshot(root.selected-id, s.filename); } } }
                                }
                            }
                        }
                    }
                }

                // ---- Backups tab ----
                if root.detail-tab == 6 : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Backs up saves, config and options.txt.";
                            color: Theme.text-dim; font-size: 11px; vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        PButton { text: "+ Create backup"; primary: true; clicked => { Logic.create-backup(root.selected-id); } }
                    }
                    if Logic.inst-backups.length == 0 : EmptyState {
                        vertical-stretch: 1;
                        icon: "⟳"; title: "No backups yet";
                        subtitle: "Create one before risky changes; restore reverts saves and config.";
                    }
                    if Logic.inst-backups.length > 0 : ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 6px;
                            for b in Logic.inst-backups : Rectangle {
                                height: 56px;
                                border-radius: Theme.radius-sm;
                                background: Theme.surface-alt;
                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text { text: b.created; color: Theme.text; font-size: 14px; font-weight: 600; overflow: elide; }
                                        Text { text: b.size; color: Theme.text-muted; font-size: 11px; }
                                    }
                                    VerticalLayout { alignment: center; PButton { text: "Restore"; clicked => { root.pending-backup = b.filename; root.pending-backup-date = b.created; root.backup-confirm-open = true; } } }
                                    VerticalLayout { alignment: center; PButton { text: "Delete"; danger: true; clicked => { Logic.delete-backup(root.selected-id, b.filename); } } }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ---- Create dialog ----
    if root.dialog-open : Dialog {
        dialog-width: 520px;
        closed => { root.dialog-open = false; root.restore-icon-picker(); }
        Text { text: "New Instance"; color: Theme.text; font-size: 18px; font-weight: 700; }

        Text { text: "Name"; color: Theme.text-muted; font-size: 12px; }
        create-name-edit := LineEdit { placeholder-text: "My instance"; }

        IconPicker {
            derived-initial: create-name-edit.text == "" ? "?" : create-name-edit.text;
            derived-color: Theme.accent;
        }

        HorizontalLayout {
            spacing: 12px;
            VerticalLayout {
                spacing: 6px;
                width: 150px;
                Text { text: "Version type"; color: Theme.text-muted; font-size: 12px; }
                type-combo := ComboBox {
                    model: ["Release", "Snapshot", "Beta", "Alpha"];
                    current-index: 0;
                    selected(val) => {
                        Logic.filter-versions(
                            val == "Release" ? "release"
                            : val == "Snapshot" ? "snapshot"
                            : val == "Beta" ? "old_beta"
                            : "old_alpha");
                    }
                }
            }
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Minecraft version"; color: Theme.text-muted; font-size: 12px; }
                version-combo := ComboBox {
                    model: Logic.version-list;
                    enabled: !Logic.versions-loading && Logic.version-list.length > 0;
                }
            }
        }
        if Logic.versions-loading : Text { text: "Loading versions…"; color: Theme.text-dim; font-size: 11px; }

        HorizontalLayout {
            spacing: 12px;
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Mod loader"; color: Theme.text-muted; font-size: 12px; }
                loader-combo := ComboBox {
                    model: root.loaders;
                    current-index: 0;
                    selected(val) => {
                        if val != "Vanilla" && version-combo.current-value != "" {
                            Logic.load-loader-versions(val, version-combo.current-value);
                        }
                    }
                }
            }
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Loader version"; color: Theme.text-muted; font-size: 12px; }
                loaderver-combo := ComboBox {
                    model: Logic.loader-version-list;
                    enabled: loader-combo.current-value != "Vanilla"
                        && !Logic.loader-versions-loading
                        && Logic.loader-version-list.length > 0;
                }
            }
        }

        VerticalLayout {
            spacing: 6px;
            Text {
                text: round(mem-create-slider.value) == 0
                    ? "Max memory: default"
                    : "Max memory: \{round(mem-create-slider.value)} MB";
                color: Theme.text-muted; font-size: 12px;
            }
            mem-create-slider := Slider {
                minimum: 0;
                maximum: Logic.system-ram-mb;
                value: 2048;
            }
        }
        VerticalLayout {
            spacing: 6px;
            Text { text: "JVM arguments"; color: Theme.text-muted; font-size: 12px; }
            jvm-create-edit := LineEdit { placeholder-text: "-XX:+UseG1GC"; }
        }

        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton {
                text: "Cancel";
                clicked => { root.dialog-open = false; root.restore-icon-picker(); }
            }
            PButton {
                text: "Create";
                primary: true;
                enabled: create-name-edit.text != "" && version-combo.current-value != "";
                clicked => {
                    Logic.create-instance(
                        create-name-edit.text,
                        version-combo.current-value,
                        loader-combo.current-value == "Vanilla" ? "" : loader-combo.current-value,
                        loader-combo.current-value == "Vanilla" ? ""
                            : (loaderver-combo.current-value == "Recommended" ? "" : loaderver-combo.current-value),
                        Logic.pending-icon-id,
                        round(mem-create-slider.value),
                        jvm-create-edit.text);
                    root.dialog-open = false;
                    root.restore-icon-picker();
                    create-name-edit.text = "";
                    mem-create-slider.value = 2048;
                    jvm-create-edit.text = "";
                }
            }
        }
    }

    // ---- Change version / loader dialog ----
    if root.version-dialog-open : Dialog {
        dialog-width: 520px;
        closed => { root.version-dialog-open = false; root.restore-icon-picker(); }
        Text { text: "Change version / loader"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "Changing the Minecraft version or mod loader does not remove your installed mods — some may become incompatible. Use 'Check for updates' afterwards.";
            color: Theme.text-dim; font-size: 11px; wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 12px;
            VerticalLayout {
                spacing: 6px;
                width: 150px;
                Text { text: "Version type"; color: Theme.text-muted; font-size: 12px; }
                ver-type-combo := ComboBox {
                    model: ["Release", "Snapshot", "Beta", "Alpha"];
                    current-index: 0;
                    selected(val) => {
                        Logic.filter-versions(
                            val == "Release" ? "release"
                            : val == "Snapshot" ? "snapshot"
                            : val == "Beta" ? "old_beta"
                            : "old_alpha");
                    }
                }
            }
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Minecraft version"; color: Theme.text-muted; font-size: 12px; }
                ver-version-combo := ComboBox {
                    model: Logic.version-list;
                    enabled: !Logic.versions-loading && Logic.version-list.length > 0;
                }
            }
        }
        if Logic.versions-loading : Text { text: "Loading versions…"; color: Theme.text-dim; font-size: 11px; }

        HorizontalLayout {
            spacing: 12px;
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Mod loader"; color: Theme.text-muted; font-size: 12px; }
                ver-loader-combo := ComboBox {
                    model: root.loaders;
                    current-value <=> root.ver-loader;
                    selected(val) => {
                        if val != "Vanilla" && ver-version-combo.current-value != "" {
                            Logic.load-loader-versions(val, ver-version-combo.current-value);
                        }
                    }
                }
            }
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;
                Text { text: "Loader version"; color: Theme.text-muted; font-size: 12px; }
                ver-loaderver-combo := ComboBox {
                    model: Logic.loader-version-list;
                    enabled: ver-loader-combo.current-value != "Vanilla"
                        && !Logic.loader-versions-loading
                        && Logic.loader-version-list.length > 0;
                }
            }
        }

        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.version-dialog-open = false; } }
            PButton {
                text: "Apply";
                primary: true;
                enabled: ver-version-combo.current-value != "";
                clicked => {
                    Logic.change-version(
                        root.selected-id,
                        ver-version-combo.current-value,
                        ver-loader-combo.current-value == "Vanilla" ? "" : ver-loader-combo.current-value,
                        ver-loader-combo.current-value == "Vanilla" ? ""
                            : (ver-loaderver-combo.current-value == "Recommended" ? "" : ver-loaderver-combo.current-value));
                    // Optimistically reflect the change in the detail header.
                    root.sel-version = ver-version-combo.current-value;
                    root.sel-loader = ver-loader-combo.current-value == "Vanilla" ? ""
                        : (ver-loader-combo.current-value == "Fabric" ? "fabric"
                        : ver-loader-combo.current-value == "NeoForge" ? "neoforge"
                        : ver-loader-combo.current-value == "Forge" ? "forge" : "");
                    root.version-dialog-open = false;
                }
            }
        }
    }

    // ---- Modrinth browse dialog (mods / resource packs / shaders) ----
    if root.browse-open : Dialog {
        dialog-width: 660px;
        closed => { root.browse-open = false; Logic.modrinth-close-detail(); }

        // Inline detail view (swaps in over the results list).
        if Logic.modrinth-detail-open : ModrinthDetailPane {
            height: 540px;
            action-text: "Install";
            back => { Logic.modrinth-close-detail(); }
            action(vid) => { Logic.modrinth-install(root.selected-id, Logic.modrinth-detail.project-id, root.browse-kind, vid); }
        }

        if !Logic.modrinth-detail-open : VerticalLayout {
            spacing: 12px;
            Text { text: "Browse " + root.browse-title; color: Theme.text; font-size: 18px; font-weight: 700; }
            HorizontalLayout {
                spacing: 8px;
                bsearch := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "Search Modrinth…";
                    accepted => { Logic.modrinth-search(self.text, root.browse-kind, root.selected-id); }
                }
                PButton { text: "Search"; primary: true; clicked => { Logic.modrinth-search(bsearch.text, root.browse-kind, root.selected-id); } }
            }
            if Logic.modrinth-loading : Text { text: "Searching…"; color: Theme.text-dim; font-size: 12px; }
            if !Logic.modrinth-loading && Logic.modrinth-status != "" : Text {
                text: Logic.modrinth-status; color: Theme.text-muted; font-size: 12px; wrap: word-wrap;
            }
            Rectangle {
                height: 360px;
                ScrollView {
                    VerticalLayout {
                        spacing: 8px;
                        for hit in Logic.modrinth-results : ModrinthRow {
                            hit: hit;
                            action-text: "Install";
                            action => { Logic.modrinth-install(root.selected-id, hit.project-id, root.browse-kind, ""); }
                            open-detail => { Logic.modrinth-open-detail(hit.project-id, root.browse-kind); }
                        }
                        if Logic.modrinth-can-load-more : HorizontalLayout {
                            padding-top: 4px;
                            alignment: center;
                            PButton {
                                text: Logic.modrinth-loading-more ? "Loading…" : "Load more";
                                enabled: !Logic.modrinth-loading-more;
                                clicked => { Logic.modrinth-load-more(); }
                            }
                        }
                    }
                }
            }
            HorizontalLayout {
                alignment: end;
                PButton { text: "Close"; clicked => { root.browse-open = false; Logic.modrinth-close-detail(); } }
            }
        }
    }

    // ---- Delete confirmation ----
    if root.confirm-open : Dialog {
        dialog-width: 400px;
        closed => { root.confirm-open = false; }
        Text { text: "Delete instance?"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "“" + root.edit-name + "” and all of its files will be permanently removed. This cannot be undone.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.confirm-open = false; } }
            PButton {
                text: "Delete";
                danger: true;
                clicked => {
                    Logic.delete-instance(root.selected-id);
                    root.selected-id = "";
                    root.confirm-open = false;
                }
            }
        }
    }

    // ---- World delete confirmation (saves are precious) ----
    if root.world-confirm-open : Dialog {
        dialog-width: 400px;
        closed => { root.world-confirm-open = false; }
        Text { text: "Delete world?"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "“" + root.pending-world + "” will be permanently deleted. Consider backing it up first. This cannot be undone.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.world-confirm-open = false; } }
            PButton {
                text: "Delete";
                danger: true;
                clicked => {
                    Logic.delete-world(root.selected-id, root.pending-world);
                    root.world-confirm-open = false;
                }
            }
        }
    }

    // ---- Backup restore confirmation (overwrites saves/config) ----
    if root.backup-confirm-open : Dialog {
        dialog-width: 420px;
        closed => { root.backup-confirm-open = false; }
        Text { text: "Restore backup?"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "Restoring the backup from " + root.pending-backup-date + " will overwrite this instance's current saves, config and options.txt.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.backup-confirm-open = false; } }
            PButton {
                text: "Restore";
                primary: true;
                clicked => {
                    Logic.restore-backup(root.selected-id, root.pending-backup);
                    root.backup-confirm-open = false;
                }
            }
        }
    }

    // ---- Mod deletion confirmation ----
    if root.mod-confirm-open : Dialog {
        dialog-width: 400px;
        closed => { root.mod-confirm-open = false; }
        Text { text: "Remove Mod?"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "Are you sure you want to remove the mod “" + root.pending-mod-name + "”? This will permanently delete the file “" + root.pending-mod-filename + "”.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.mod-confirm-open = false; } }
            PButton {
                text: "Remove";
                danger: true;
                clicked => {
                    Logic.remove-mod(root.selected-id, root.pending-mod-filename);
                    root.mod-confirm-open = false;
                }
            }
        }
    }

    // ---- Resource pack / Shader pack deletion confirmation ----
    if root.pack-confirm-open : Dialog {
        dialog-width: 400px;
        closed => { root.pack-confirm-open = false; }
        Text {
            text: root.pending-pack-type == "resourcepack" ? "Delete Resource Pack?" : "Delete Shader?";
            color: Theme.text; font-size: 18px; font-weight: 700;
        }
        Text {
            text: "Are you sure you want to delete “" + root.pending-pack-name + "”? This will permanently delete the file/directory “" + root.pending-pack-filename + "”. This cannot be undone.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.pack-confirm-open = false; } }
            PButton {
                text: "Delete";
                danger: true;
                clicked => {
                    if root.pending-pack-type == "resourcepack" {
                        Logic.delete-resourcepack(root.selected-id, root.pending-pack-filename);
                    } else {
                        Logic.delete-shaderpack(root.selected-id, root.pending-pack-filename);
                    }
                    root.pack-confirm-open = false;
                }
            }
        }
    }
}
