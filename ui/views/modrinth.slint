import { Theme, Logic, Lightbox, Icons, ModrinthHit, ModrinthVersionRow } from "../globals.slint";
import { Card, PButton, Avatar, EmptyState, Dialog, Icon, Badge, LoaderBadge } from "../components.slint";
import { ScrollView, LineEdit, ComboBox, Slider } from "std-widgets.slint";

// A single Modrinth result row: thumbnail, title/description/meta, action button.
// Reused by the modpack browser here and the in-detail browse dialog. Clicking
// the row body opens the detail; the action button is a quick install/create.
export component ModrinthRow inherits Rectangle {
    in property <ModrinthHit> hit;
    in property <string> action-text: "Install";
    in property <bool> action-busy;
    callback action();
    callback open-detail();
    height: 88px;
    border-radius: Theme.radius-sm;
    background: row-touch.has-hover ? Theme.surface-hover : Theme.surface-alt;
    animate background { duration: 100ms; }
    clip: true;
    row-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.open-detail(); }
    }
    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: Theme.surface;
                clip: true;
                Icon { width: 100%; height: 100%; icon: Icons.package; color: Theme.text-dim; font-size: 24px; }
                Image { width: 100%; height: 100%; source: root.hit.icon; image-fit: contain; }
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 3px;
            Text { text: root.hit.title; color: Theme.text; font-size: 15px; font-weight: 700; overflow: elide; }
            Text { text: root.hit.description; color: Theme.text-muted; font-size: 12px; overflow: elide; }
            HorizontalLayout {
                spacing: 12px;
                alignment: start;
                Text { text: "by " + root.hit.author; color: Theme.text-dim; font-size: 11px; }
                Text { text: "↓ " + root.hit.downloads; color: Theme.text-dim; font-size: 11px; }
            }
        }
        VerticalLayout {
            alignment: center;
            PButton {
                text: root.action-text;
                primary: true;
                enabled: !root.action-busy;
                clicked => { root.action(); }
            }
        }
    }
}

// Pill-style tab button used by the detail page's section switcher.
component DetailTab inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();
    height: 34px;
    horizontal-stretch: 0;
    border-radius: Theme.radius-sm;
    background: root.active ? Theme.accent : (ta.has-hover ? Theme.surface-hover : transparent);
    animate background { duration: 100ms; }
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.label;
            color: root.active ? Theme.accent-text : Theme.text;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// A titled block inside the right-hand info sidebar.
component SideSection inherits VerticalLayout {
    in property <string> title;
    spacing: 8px;
    Text { text: root.title; color: Theme.text; font-size: 14px; font-weight: 700; }
    @children
}

// Small muted sub-label inside a sidebar section.
component SideLabel inherits Text {
    color: Theme.text-muted;
    font-size: 12px;
    font-weight: 600;
}

// One link line in the sidebar's Links section.
component SideLink inherits Rectangle {
    in property <string> label;
    in property <string> url;
    callback clicked();
    height: 26px;
    border-radius: Theme.radius-sm;
    background: la.has-hover ? Theme.surface-hover : transparent;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 6px;
        Text { text: root.label; color: Theme.accent; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        Text { text: "↗"; color: Theme.text-dim; font-size: 12px; vertical-alignment: center; }
    }
    la := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// One row in the Versions tab table.
component VersionListRow inherits Rectangle {
    in property <ModrinthVersionRow> ver;
    in property <string> action-text;
    in property <bool> compact;
    callback action();
    height: 56px;
    border-radius: Theme.radius-sm;
    background: vt.has-hover ? Theme.surface-hover : Theme.surface-alt;
    animate background { duration: 100ms; }
    vt := TouchArea { }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        // Name + version number
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text { text: root.ver.name; color: Theme.text; font-size: 13px; font-weight: 700; overflow: elide; }
            Text { text: root.ver.version-number; color: Theme.text-dim; font-size: 11px; overflow: elide; }
        }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: start;
                if root.ver.game-version != "" : Badge { text: root.ver.game-version; tint: Theme.text-muted; }
            }
            width: 64px;
        }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: start;
                if root.ver.loader != "" : LoaderBadge { loader: root.ver.loader; }
            }
            width: 76px;
        }
        if !root.compact : VerticalLayout {
            alignment: center;
            width: 80px;
            Text { text: root.ver.date; color: Theme.text-dim; font-size: 11px; }
        }
        VerticalLayout {
            alignment: center;
            width: 56px;
            Text { text: "↓ " + root.ver.downloads; color: Theme.text-dim; font-size: 11px; }
        }
        VerticalLayout {
            alignment: center;
            PButton { text: root.action-text; primary: true; clicked => { root.action(); } }
        }
    }
}

// Full project detail laid out like the Modrinth website: a header with stats
// and tags, a pill tab bar (Description / Gallery / Versions), and — when not
// `compact` — a right-hand info sidebar (Compatibility / Links / Tags).
// Reads the `Logic.modrinth-detail` global; the parent supplies the action label
// and handles `back()` / `action(version-id)`.
export component ModrinthDetailPane inherits VerticalLayout {
    in property <string> action-text: "Install";        // header (latest) action
    in property <string> row-action-text: "Install";    // per-version action
    in property <bool> compact: false;                  // hide sidebar (narrow modal)
    callback back();
    callback action(string /* version-id */);
    property <int> tab: 0;   // 0 = Description, 1 = Gallery, 2 = Versions
    spacing: 12px;

    HorizontalLayout {
        PButton { text: "Back"; icon: Icons.caret-left; clicked => { root.back(); } }
        Rectangle { horizontal-stretch: 1; }
    }

    if Logic.modrinth-detail-loading : Text { text: "Loading…"; color: Theme.text-dim; font-size: 13px; }

    if !Logic.modrinth-detail-loading : VerticalLayout {
        spacing: 14px;
        vertical-stretch: 1;

        // ---- Header card ----
        Card {
            VerticalLayout {
                padding: 16px;
                spacing: 10px;
                HorizontalLayout {
                    spacing: 14px;
                    Rectangle {
                        width: 72px; height: 72px; border-radius: Theme.radius-sm; background: Theme.surface; clip: true;
                        Icon { width: 100%; height: 100%; icon: Icons.package; color: Theme.text-dim; font-size: 30px; }
                        Image { width: 100%; height: 100%; source: Logic.modrinth-detail.icon; image-fit: contain; }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 5px;
                        horizontal-stretch: 1;
                        Text { text: Logic.modrinth-detail.title; color: Theme.text; font-size: 22px; font-weight: 800; overflow: elide; }
                        if Logic.modrinth-detail.description != "" : Text {
                            text: Logic.modrinth-detail.description; color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 16px;
                            alignment: start;
                            Text { text: "↓ " + Logic.modrinth-detail.downloads; color: Theme.text-dim; font-size: 12px; }
                            Text { text: "♥ " + Logic.modrinth-detail.follows; color: Theme.text-dim; font-size: 12px; }
                            Text { text: "by " + Logic.modrinth-detail.author; color: Theme.text-dim; font-size: 12px; }
                            if Logic.modrinth-detail.updated != "" : Text { text: "updated " + Logic.modrinth-detail.updated; color: Theme.text-dim; font-size: 12px; }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        PButton {
                            text: root.action-text;
                            primary: true;
                            enabled: Logic.modrinth-detail.version-ids.length > 0;
                            clicked => { root.action(""); }
                        }
                    }
                }
            }
        }

        // ---- Tab bar ----
        HorizontalLayout {
            spacing: 6px;
            DetailTab { label: "Description"; active: root.tab == 0; clicked => { root.tab = 0; } }
            DetailTab { label: "Gallery (" + Logic.modrinth-detail.gallery.length + ")"; active: root.tab == 1; clicked => { root.tab = 1; } }
            DetailTab { label: "Versions (" + Logic.modrinth-detail.versions.length + ")"; active: root.tab == 2; clicked => { root.tab = 2; } }
            Rectangle { horizontal-stretch: 1; }
        }

        // ---- Body: content (+ optional sidebar) ----
        HorizontalLayout {
            spacing: 16px;
            vertical-stretch: 1;

            // Left: the active tab's content.
            VerticalLayout {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                // Description
                if root.tab == 0 : Card {
                    vertical-stretch: 1;
                    ScrollView {
                        VerticalLayout {
                            padding: 14px;
                            Text {
                                text: Logic.modrinth-detail.body != "" ? Logic.modrinth-detail.body : Logic.modrinth-detail.description;
                                color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
                            }
                        }
                    }
                }

                // Gallery — responsive 2-column grid of captioned thumbnails.
                if root.tab == 1 : Card {
                    vertical-stretch: 1;
                    if Logic.modrinth-detail.gallery.length == 0 : EmptyState {
                        icon: Icons.image; title: "No gallery images";
                    }
                    if Logic.modrinth-detail.gallery.length > 0 : ScrollView {
                        VerticalLayout {
                            padding: 12px;
                            GridLayout {
                                spacing: 10px;
                                for img[idx] in Logic.modrinth-detail.gallery : Rectangle {
                                    row: floor(idx / 2);
                                    col: mod(idx, 2);
                                    height: 150px;
                                    border-radius: Theme.radius-sm;
                                    background: Theme.surface;
                                    clip: true;
                                    Image { width: 100%; height: 100%; source: img; image-fit: cover; }
                                    // Caption gradient strip along the bottom.
                                    if idx < Logic.modrinth-detail.gallery-titles.length && Logic.modrinth-detail.gallery-titles[idx] != "" : Rectangle {
                                        y: parent.height - self.height;
                                        height: 28px;
                                        background: #000000aa;
                                        Text {
                                            x: 8px;
                                            width: parent.width - 16px;
                                            text: Logic.modrinth-detail.gallery-titles[idx];
                                            color: white; font-size: 11px; overflow: elide; vertical-alignment: center;
                                        }
                                    }
                                    gal-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { Lightbox.show(Logic.modrinth-detail.gallery, Logic.modrinth-detail.gallery-titles, idx); }
                                    }
                                }
                            }
                        }
                    }
                }

                // Versions
                if root.tab == 2 : Card {
                    vertical-stretch: 1;
                    if Logic.modrinth-detail.versions.length == 0 : EmptyState {
                        icon: Icons.package; title: "No versions available";
                    }
                    if Logic.modrinth-detail.versions.length > 0 : ScrollView {
                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;
                            for ver in Logic.modrinth-detail.versions : VersionListRow {
                                ver: ver;
                                compact: root.compact;
                                action-text: root.row-action-text;
                                action => { root.action(ver.id); }
                            }
                        }
                    }
                }
            }

            // Right: info sidebar (hidden in compact mode).
            if !root.compact : Rectangle {
                width: 232px;
                vertical-stretch: 1;
                ScrollView {
                    VerticalLayout {
                        spacing: 14px;

                        // Compatibility
                        if Logic.modrinth-detail.game-versions.length > 0 || Logic.modrinth-detail.loaders.length > 0 || Logic.modrinth-detail.environments.length > 0 : Card {
                            vertical-stretch: 0;
                            VerticalLayout {
                                padding: 14px;
                                SideSection {
                                    title: "Compatibility";
                                    if Logic.modrinth-detail.game-versions.length > 0 : SideLabel { text: "Minecraft"; }
                                    if Logic.modrinth-detail.game-versions.length > 0 : GridLayout {
                                        spacing: 6px;
                                        for gv[i] in Logic.modrinth-detail.game-versions : HorizontalLayout {
                                            row: floor(i / 2);
                                            col: mod(i, 2);
                                            alignment: start;
                                            Badge { text: gv; tint: Theme.text-muted; }
                                        }
                                    }
                                    if Logic.modrinth-detail.loaders.length > 0 : SideLabel { text: "Platforms"; }
                                    if Logic.modrinth-detail.loaders.length > 0 : HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        for ld in Logic.modrinth-detail.loaders : LoaderBadge { loader: ld; }
                                    }
                                    if Logic.modrinth-detail.environments.length > 0 : SideLabel { text: "Environments"; }
                                    if Logic.modrinth-detail.environments.length > 0 : HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        for env in Logic.modrinth-detail.environments : Badge { text: env; tint: Theme.accent; }
                                    }
                                }
                            }
                        }

                        // Links
                        if Logic.modrinth-detail.page-url != "" || Logic.modrinth-detail.source-url != "" || Logic.modrinth-detail.issues-url != "" || Logic.modrinth-detail.wiki-url != "" || Logic.modrinth-detail.discord-url != "" : Card {
                            vertical-stretch: 0;
                            VerticalLayout {
                                padding: 14px;
                                SideSection {
                                    title: "Links";
                                    if Logic.modrinth-detail.page-url != "" : SideLink { label: "Modrinth page"; clicked => { Logic.open-url(Logic.modrinth-detail.page-url); } }
                                    if Logic.modrinth-detail.source-url != "" : SideLink { label: "Source"; clicked => { Logic.open-url(Logic.modrinth-detail.source-url); } }
                                    if Logic.modrinth-detail.issues-url != "" : SideLink { label: "Report issues"; clicked => { Logic.open-url(Logic.modrinth-detail.issues-url); } }
                                    if Logic.modrinth-detail.wiki-url != "" : SideLink { label: "Wiki"; clicked => { Logic.open-url(Logic.modrinth-detail.wiki-url); } }
                                    if Logic.modrinth-detail.discord-url != "" : SideLink { label: "Discord"; clicked => { Logic.open-url(Logic.modrinth-detail.discord-url); } }
                                }
                            }
                        }

                        // Tags
                        if Logic.modrinth-detail.categories-list.length > 0 : Card {
                            vertical-stretch: 0;
                            VerticalLayout {
                                padding: 14px;
                                SideSection {
                                    title: "Tags";
                                    GridLayout {
                                        spacing: 6px;
                                        for cat[i] in Logic.modrinth-detail.categories-list : HorizontalLayout {
                                            row: floor(i / 2);
                                            col: mod(i, 2);
                                            alignment: start;
                                            Badge { text: cat; tint: Theme.accent; }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }
        }
    }
}

export component ModrinthView inherits Rectangle {
    property <bool> create-open: false;
    property <ModrinthHit> pending-pack;
    property <ModrinthHit> detail-hit;   // the row whose detail is open
    property <string> create-name;
    property <string> pending-version-id; // "" = latest, else a chosen version
    // Empty image, used as the "no photo" fallback for the icon preview.
    property <image> no-image;

    // Show popular modpacks on first open.
    init => { Logic.modrinth-search("", "modpack", ""); }

    // Open the create-from-pack dialog for a pack at a specific version ("" = latest).
    function open-create(pack: ModrinthHit, version-id: string) {
        root.pending-pack = pack;
        root.create-name = pack.title;
        root.pending-version-id = version-id;
        Logic.pending-icon-id = "modpack";
        Logic.pending-icon-glyph = "";
        Logic.reset-pending-icon-file();
        root.create-open = true;
    }

    VerticalLayout {
        padding: 24px;
        spacing: 14px;

        if Logic.modrinth-detail-open : ModrinthDetailPane {
            vertical-stretch: 1;
            action-text: "Create instance…";
            row-action-text: "Create";
            back => { Logic.modrinth-close-detail(); }
            action(vid) => { root.open-create(root.detail-hit, vid); }
        }

        if !Logic.modrinth-detail-open : VerticalLayout {
            spacing: 14px;
            vertical-stretch: 1;

            HorizontalLayout {
                spacing: 8px;
                search := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "Search modpacks…";
                    accepted => { Logic.modrinth-search(self.text, "modpack", ""); }
                }
                PButton { text: "Search"; primary: true; clicked => { Logic.modrinth-search(search.text, "modpack", ""); } }
            }

            if Logic.modrinth-loading : Text { text: "Searching…"; color: Theme.text-dim; font-size: 12px; }
            if !Logic.modrinth-loading && Logic.modrinth-status != "" : Text {
                text: Logic.modrinth-status; color: Theme.text-muted; font-size: 12px; wrap: word-wrap;
            }

            if Logic.modrinth-results.length == 0 && !Logic.modrinth-loading : EmptyState {
                vertical-stretch: 1;
                icon: Icons.package;
                title: "Browse Modrinth modpacks";
                subtitle: "Search for a modpack and create a configurable instance from it.";
            }

            if Logic.modrinth-results.length > 0 : Card {
                vertical-stretch: 1;
                ScrollView {
                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;
                        for hit in Logic.modrinth-results : ModrinthRow {
                            hit: hit;
                            action-text: "Create instance…";
                            action => { root.open-create(hit, ""); }
                            open-detail => {
                                root.detail-hit = hit;
                                Logic.modrinth-open-detail(hit.project-id, "modpack");
                            }
                        }
                        if Logic.modrinth-can-load-more : HorizontalLayout {
                            padding-top: 4px;
                            alignment: center;
                            PButton {
                                text: Logic.modrinth-loading-more ? "Loading…" : "Load more";
                                enabled: !Logic.modrinth-loading-more;
                                clicked => { Logic.modrinth-load-more(); }
                            }
                        }
                    }
                }
            }
        }
    }

    // ---- Create-from-pack dialog ----
    if root.create-open : Dialog {
        dialog-width: 520px;
        closed => { root.create-open = false; }

        Text {
            text: "Create instance from “" + root.pending-pack.title + "”";
            color: Theme.text; font-size: 18px; font-weight: 700; wrap: word-wrap;
        }

        Text { text: "Name"; color: Theme.text-muted; font-size: 12px; }
        LineEdit { text <=> root.create-name; placeholder-text: "Instance name"; }

        Text { text: "Icon"; color: Theme.text-muted; font-size: 12px; }
        HorizontalLayout {
            spacing: 14px;
            VerticalLayout {
                alignment: start;
                Avatar {
                    initial: Logic.pending-icon-glyph != "" ? Logic.pending-icon-glyph : (root.create-name == "" ? "?" : root.create-name);
                    icon-font: Logic.pending-icon-glyph != "";
                    tint: Theme.accent;
                    size: 56px;
                    photo: Logic.pending-icon-id == "modpack" ? root.pending-pack.icon
                        : Logic.pending-icon-id == "custom" ? Logic.pending-icon-image
                        : root.no-image;
                }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 8px;
                GridLayout {
                    spacing: 6px;
                    for opt[i] in Logic.icon-options : Rectangle {
                        row: floor(i / 6);
                        col: mod(i, 6);
                        width: 34px;
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Logic.pending-icon-id == opt.id ? Theme.surface-alt : (sw.has-hover ? Theme.surface-hover : transparent);
                        border-width: 1px;
                        border-color: Logic.pending-icon-id == opt.id ? Theme.accent : Theme.border;
                        animate background, border-color { duration: 100ms; }
                        Text { text: opt.glyph; color: Theme.text; font-family: Icons.font; font-size: 19px; horizontal-alignment: center; vertical-alignment: center; }
                        sw := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { Logic.pending-icon-id = opt.id; Logic.pending-icon-glyph = opt.glyph; }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    PButton { text: "Pack icon"; clicked => { Logic.pending-icon-id = "modpack"; Logic.pending-icon-glyph = ""; } }
                    PButton { text: "Monogram"; clicked => { Logic.pending-icon-id = ""; Logic.pending-icon-glyph = ""; } }
                    PButton { text: "Choose file…"; clicked => { Logic.pick-custom-icon(); } }
                }
            }
        }

        VerticalLayout {
            spacing: 6px;
            Text {
                text: round(mem.value) == 0 ? "Max memory: default" : "Max memory: \{round(mem.value)} MB";
                color: Theme.text-muted; font-size: 12px;
            }
            mem := Slider {
                minimum: 0;
                maximum: Logic.system-ram-mb;
                value: 2048;
            }
        }
        VerticalLayout {
            spacing: 6px;
            Text { text: "JVM arguments"; color: Theme.text-muted; font-size: 12px; }
            jvm := LineEdit { placeholder-text: "-XX:+UseG1GC"; }
        }

        Text {
            text: "The pack's own Minecraft version and mod loader are used automatically.";
            color: Theme.text-dim; font-size: 11px; wrap: word-wrap;
        }

        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.create-open = false; } }
            PButton {
                text: "Create";
                primary: true;
                enabled: root.create-name != "";
                clicked => {
                    Logic.modrinth-create-instance(
                        root.pending-pack.project-id,
                        root.create-name,
                        Logic.pending-icon-id,
                        round(mem.value),
                        jvm.text,
                        root.pending-version-id);
                    root.create-open = false;
                }
            }
        }
    }
}
