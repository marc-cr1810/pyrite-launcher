import { Theme, Logic, Icons, LogLine, AccountItem, InstanceItem } from "../globals.slint";
import { Card, PButton, PProgress, Avatar, Badge, LoaderBadge, EmptyState, Icon } from "../components.slint";
import { ScrollView } from "std-widgets.slint";

component PopupRow inherits Rectangle {
    in property <string> initial;
    in property <bool> icon-font;
    in property <color> tint;
    in property <image> photo;
    in property <string> title;
    in property <string> subtitle;
    in property <bool> selected;
    callback clicked();
    height: 48px;
    border-radius: Theme.radius-sm;
    background: selected ? Theme.surface-alt : (rowtouch.has-hover ? Theme.surface-hover : transparent);
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            Avatar { initial: root.initial; icon-font: root.icon-font; tint: root.tint; photo: root.photo; size: 32px; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 1px;
            horizontal-stretch: 1;
            Text { text: root.title; color: Theme.text; font-size: 14px; font-weight: 600; overflow: elide; }
            Text { text: root.subtitle; color: Theme.text-muted; font-size: 11px; overflow: elide; }
        }
        if root.selected : Icon { icon: Icons.check; color: Theme.accent; font-size: 15px; }
    }
    rowtouch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// The instance/account picker list, shared by both hero triggers. Lives as a
// child of a trigger element; call `.show()` from that trigger's TouchArea.
// Position (x/y/width) is set where it's instantiated, relative to the trigger.
component SelectorPopup inherits PopupWindow {
    in property <string> kind; // "instance" | "account"
    // Size the popup to its content (capped) so the opaque background and hit
    // area cover the rows instead of overflowing the page.
    height: min(280px, list.preferred-height);
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.surface;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-color: #00000066;
        drop-shadow-blur: 20px;
        drop-shadow-offset-y: 6px;
        clip: true;
        ScrollView {
            width: 100%;
            height: 100%;
            list := VerticalLayout {
                width: 100%;
                padding: 6px;
                spacing: 2px;

                if root.kind == "instance" : VerticalLayout {
                    spacing: 2px;
                    if Logic.instances.length == 0 : Text {
                        text: "No instances"; color: Theme.text-dim; font-size: 12px;
                    }
                    for inst in Logic.instances : PopupRow {
                        initial: inst.icon-glyph != "" ? inst.icon-glyph : inst.initial;
                        icon-font: inst.icon-glyph != "";
                        tint: inst.avatar-color;
                        photo: inst.icon-image;
                        title: inst.name;
                        subtitle: inst.version + (inst.loader == "" ? "" : "  •  " + inst.loader);
                        selected: inst.active;
                        clicked => { Logic.select-instance(inst.id); }
                    }
                }
                if root.kind == "account" : VerticalLayout {
                    spacing: 2px;
                    if Logic.accounts.length == 0 : Text {
                        text: "No accounts"; color: Theme.text-dim; font-size: 12px;
                    }
                    for acc in Logic.accounts : PopupRow {
                        initial: acc.initial;
                        tint: acc.avatar-color;
                        photo: acc.avatar;
                        title: acc.username;
                        subtitle: acc.kind;
                        selected: acc.active;
                        clicked => { Logic.select-account(acc.uuid); }
                    }
                }
            }
        }
    }
}

export component PlayView inherits VerticalLayout {
    padding: 24px;
    spacing: 20px;

    property <bool> errors-only: false;

    // ---- Hero: identity + selection + the one big action ----
    Card {
        height: 150px;
        HorizontalLayout {
            padding: 20px;
            spacing: 16px;

            // Instance identity — click to switch instances. A bare Rectangle
            // doesn't adopt its child layout's size, so bind the width to the
            // inner content; that keeps the caret hugging the name.
            inst-trigger := Rectangle {
                horizontal-stretch: 0;
                width: inst-inner.preferred-width;
                border-radius: Theme.radius-sm;
                background: inst-touch.has-hover ? Theme.surface-hover : transparent;
                animate background { duration: 100ms; }
                inst-inner := HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 10px;
                    spacing: 14px;
                    VerticalLayout {
                        alignment: center;
                        Avatar {
                            initial: Logic.active-instance-name == "" ? "?"
                                : Logic.active-instance-glyph != "" ? Logic.active-instance-glyph
                                : Logic.active-instance-initial;
                            icon-font: Logic.active-instance-name != "" && Logic.active-instance-glyph != "";
                            tint: Logic.active-instance-name == "" ? Theme.text-dim : Logic.active-instance-color;
                            size: 64px;
                            photo: Logic.active-instance-image;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 6px;
                        Text {
                            text: Logic.active-instance-name == "" ? "No instance selected" : Logic.active-instance-name;
                            color: Theme.text;
                            font-size: 22px;
                            font-weight: 700;
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text {
                                text: Logic.active-instance-version == "" ? "—" : Logic.active-instance-version;
                                color: Theme.text-muted;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                            if Logic.active-instance-loader != "" : LoaderBadge {
                                loader: Logic.active-instance-loader;
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Icon { icon: Icons.caret-down; color: Theme.text-muted; font-size: 14px; }
                    }
                }
                inst-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { inst-popup.show(); }
                }
                inst-popup := SelectorPopup {
                    kind: "instance";
                    x: 0;
                    y: parent.height + 6px;
                    width: 320px;
                }
            }

            // At-a-glance playtime stats, sitting alongside the identity (only
            // meaningful with an instance selected).
            if Logic.active-instance-name != "" : VerticalLayout {
                alignment: center;
                spacing: 8px;
                horizontal-stretch: 0;
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    Icon { icon: Icons.clock; color: Theme.text-dim; font-size: 13px; }
                    Text {
                        text: Logic.active-instance-last-played == "" ? "Never" : Logic.active-instance-last-played;
                        color: Theme.text-muted; font-size: 13px; vertical-alignment: center;
                    }
                }
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    Icon { icon: Icons.timer; color: Theme.text-dim; font-size: 13px; }
                    Text {
                        text: Logic.active-instance-playtime == "" ? "—" : Logic.active-instance-playtime;
                        color: Theme.text-muted; font-size: 13px; vertical-alignment: center;
                    }
                }
            }

            // Push the account + Play controls to the right edge.
            Rectangle { horizontal-stretch: 1; }

            // Account — click to switch accounts. Width bound to its content for
            // the same reason as the instance trigger.
            acc-trigger := Rectangle {
                horizontal-stretch: 0;
                width: acc-inner.preferred-width;
                border-radius: Theme.radius-sm;
                background: acc-touch.has-hover ? Theme.surface-hover : Theme.surface-alt;
                border-width: 1px;
                border-color: Theme.border;
                animate background { duration: 100ms; }
                acc-inner := HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 10px;
                    if Logic.active-account-name != "" : VerticalLayout {
                        alignment: center;
                        Avatar {
                            initial: Logic.active-account-initial;
                            tint: Logic.active-account-color;
                            size: 34px;
                            photo: Logic.active-account-avatar;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        horizontal-stretch: 1;
                        Text { text: "Account"; color: Theme.text-dim; font-size: 11px; font-weight: 600; }
                        Text {
                            text: Logic.active-account-name == "" ? "Select…" : Logic.active-account-name;
                            color: Theme.text; font-size: 15px; font-weight: 600; overflow: elide;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Icon { icon: Icons.caret-down; color: Theme.text-muted; font-size: 14px; }
                    }
                }
                acc-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { acc-popup.show(); }
                }
                acc-popup := SelectorPopup {
                    kind: "account";
                    x: 0;
                    y: parent.height + 6px;
                    width: 280px;
                }
            }

            VerticalLayout {
                alignment: center;
                PButton {
                    icon: Logic.game-running || Logic.is-busy ? "" : Icons.play;
                    text: Logic.game-running ? "Stop" : Logic.is-busy ? "Working…" : "Play";
                    primary: !Logic.game-running;
                    danger: Logic.game-running;
                    // Stop is always actionable while the game lives; Play needs a
                    // valid selection and no launch already in flight.
                    enabled: Logic.game-running || (Logic.can-play && !Logic.is-busy);
                    min-width: 170px;
                    height: 56px;
                    clicked => {
                        if (Logic.game-running) { Logic.stop-game(); } else { Logic.play(); }
                    }
                }
            }
        }
    }

    if !Logic.can-play && !Logic.is-busy : Text {
        text: "Pick an instance and an account above to start playing.";
        color: Theme.warning;
        font-size: 13px;
    }

    // ---- Pre-flight conflict check (shown when the active instance's mod set
    // has duplicates or missing dependencies; each issue may offer a fix) ----
    if Logic.preflight-visible : Rectangle {
        vertical-stretch: 0;
        border-radius: Theme.radius;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.warning;
        clip: true;
        HorizontalLayout {
            Rectangle { width: 4px; background: Theme.warning; }
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                HorizontalLayout {
                    spacing: 8px;
                    Icon { icon: Icons.warning; color: Theme.warning; font-size: 16px; }
                    Text {
                        text: "Before you play"; color: Theme.text; font-size: 15px; font-weight: 700;
                        horizontal-stretch: 1; vertical-alignment: center;
                    }
                    PButton { text: "Dismiss"; ghost: true; height: 26px; clicked => { Logic.dismiss-preflight(); } }
                }
                for issue in Logic.preflight-issues : HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: issue.message; color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
                        horizontal-stretch: 1; vertical-alignment: center;
                    }
                    if issue.fix-kind != "" : PButton {
                        text: Logic.preflight-fixing ? "Working…" : issue.fix-label;
                        height: 28px;
                        enabled: !Logic.preflight-fixing;
                        clicked => { Logic.preflight-fix(issue.fix-kind, issue.fix-arg); }
                    }
                }
            }
        }
    }

    // ---- Progress ----
    if Logic.progress-active : VerticalLayout {
        // Pin to natural height; the log Card below absorbs the leftover space.
        vertical-stretch: 0;
        spacing: 6px;
        HorizontalLayout {
            Text { text: Logic.status-text; color: Theme.text-muted; font-size: 13px; horizontal-stretch: 1; overflow: elide; }
            if !Logic.progress-indeterminate : Text {
                text: "\{round(clamp(Logic.progress-value, 0.0, 1.0) * 100)}%";
                color: Theme.accent; font-size: 13px; font-weight: 600;
            }
        }
        PProgress { value: Logic.progress-value; indeterminate: Logic.progress-indeterminate; }
    }

    // ---- Crash diagnostics panel (inline; persists until dismissed/next launch) ----
    if Logic.crash-visible : crash-panel := Rectangle {
        property <color> accent:
            Logic.crash-category == "mod" ? Theme.error
            : Logic.crash-category == "graphics" ? Theme.accent
            : Logic.crash-category == "unknown" ? Theme.text-muted
            : Theme.warning; // java / memory
        vertical-stretch: 0;
        border-radius: Theme.radius;
        background: Theme.surface;
        border-width: 1px;
        border-color: crash-panel.accent;
        clip: true;
        HorizontalLayout {
            // Category accent stripe.
            Rectangle { width: 4px; background: crash-panel.accent; }
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                HorizontalLayout {
                    spacing: 8px;
                    Icon { icon: Icons.warning; color: crash-panel.accent; font-size: 17px; }
                    Text {
                        text: Logic.crash-title; color: Theme.text; font-size: 16px; font-weight: 700;
                        horizontal-stretch: 1; vertical-alignment: center; overflow: elide;
                    }
                    PButton { text: "Dismiss"; ghost: true; height: 26px; clicked => { Logic.crash-visible = false; } }
                }
                Text { text: Logic.crash-description; color: Theme.text-muted; font-size: 13px; wrap: word-wrap; }

                Text { text: "What to try"; color: Theme.text; font-size: 13px; font-weight: 600; }
                for sol in Logic.crash-solutions : HorizontalLayout {
                    spacing: 6px;
                    Text { text: "•"; color: crash-panel.accent; font-size: 13px; }
                    Text { text: sol; color: Theme.text-muted; font-size: 13px; wrap: word-wrap; horizontal-stretch: 1; }
                }

                if Logic.crash-excerpt.length > 0 : Rectangle {
                    border-radius: Theme.radius-sm;
                    background: Theme.surface-alt;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 2px;
                        for line in Logic.crash-excerpt : Text {
                            text: line; color: Theme.error; font-size: 11px; font-family: "monospace"; wrap: word-wrap;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    padding-top: 2px;
                    // One-click remedy, when the cause is specific enough to act on.
                    if Logic.crash-fix-kind != "" : PButton {
                        text: Logic.crash-fixing ? "Working…" : Logic.crash-fix-label;
                        primary: true;
                        height: 28px;
                        enabled: !Logic.crash-fixing;
                        clicked => { Logic.apply-crash-fix(Logic.crash-fix-kind, Logic.crash-fix-arg); }
                    }
                    if Logic.crash-report-path != "" : PButton {
                        text: "Open crash report"; ghost: true; height: 28px; clicked => { Logic.open-crash-report(); }
                    }
                    PButton { text: "Copy details"; ghost: true; height: 28px; clicked => { Logic.copy-crash-details(); } }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }
    }

    // ---- Log toolbar + view ----
    HorizontalLayout {
        spacing: 10px;
        Text { text: "Game log"; color: Theme.text-muted; font-size: 13px; font-weight: 600; vertical-alignment: center; }
        Rectangle { }
        PButton {
            text: errors-only ? "Show all" : "Errors only";
            ghost: true;
            height: 28px;
            enabled: Logic.log-lines.length > 0;
            clicked => { errors-only = !errors-only; }
        }
        PButton { text: "Copy"; ghost: true; height: 28px; enabled: Logic.log-lines.length > 0; clicked => { Logic.copy-logs(); } }
        PButton { text: "Clear"; ghost: true; height: 28px; enabled: Logic.log-lines.length > 0; clicked => { Logic.clear-logs(); } }
    }

    // The log fills the remaining page. When there's no output it shows a
    // centered empty state (rather than a bare black box) so the space reads
    // as intentional; once lines stream in it switches to the scrolling view.
    Card {
        vertical-stretch: 1;
        clip: true;
        if Logic.log-lines.length == 0 : EmptyState {
            icon: Icons.play;
            title: "No output yet";
            subtitle: "Press Play to launch — the game's log will stream here.";
        }
        if Logic.log-lines.length > 0 : log-scroll := ScrollView {
            changed viewport-height => {
                self.viewport-y = min(0, self.visible-height - self.viewport-height);
            }
            VerticalLayout {
                padding: 12px;
                spacing: 2px;
                for line in Logic.log-lines : Rectangle {
                    property <bool> shown: !root.errors-only || line.level == "error" || line.level == "warn";
                    height: shown ? txt.preferred-height : 0;
                    clip: true;
                    txt := Text {
                        width: 100%;
                        text: line.text;
                        color: line.level == "error" ? Theme.error
                            : line.level == "warn" ? Theme.warning
                            : line.level == "plain" ? Theme.text-dim
                            : Theme.text-muted;
                        font-size: 12px;
                        font-family: "monospace";
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
