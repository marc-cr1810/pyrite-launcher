import { Theme, Logic, AccountItem } from "../globals.slint";
import { Card, PButton, Avatar, Badge, EmptyState, Dialog } from "../components.slint";
import { ScrollView, LineEdit } from "std-widgets.slint";

export component AccountsView inherits Rectangle {
    property <bool> confirm-open: false;
    property <string> pending-uuid;
    property <string> pending-name;

    VerticalLayout {
        padding: 24px;
        spacing: 18px;

        HorizontalLayout {
            Rectangle { }
            PButton {
                text: "+ Microsoft";
                primary: true;
                clicked => { Logic.start-microsoft(); }
            }
        }

        // Add offline row
        Card {
            height: 70px;
            HorizontalLayout {
                padding: 14px;
                spacing: 10px;
                offline-name := LineEdit {
                    placeholder-text: "Offline username";
                    width: 260px;
                }
                PButton {
                    text: "Add offline";
                    clicked => {
                        if offline-name.text != "" {
                            Logic.add-offline(offline-name.text);
                            offline-name.text = "";
                        }
                    }
                }
                Rectangle { }
            }
        }

        Card {
            vertical-stretch: 1;
            if Logic.accounts.length == 0 : EmptyState {
                icon: "◑";
                title: "No accounts yet";
                subtitle: "Add a Microsoft account to play online, or an offline name for local play.";
            }
            if Logic.accounts.length > 0 : ScrollView {
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    for acc in Logic.accounts : Rectangle {
                        height: 60px;
                        border-radius: Theme.radius-sm;
                        background: acc.active ? Theme.surface-alt : transparent;
                        border-width: 1px;
                        border-color: acc.active ? Theme.accent : transparent;
                        HorizontalLayout {
                            padding: 12px;
                            spacing: 12px;
                            VerticalLayout {
                                alignment: center;
                                Avatar { initial: acc.initial; tint: acc.avatar-color; size: 38px; selected: acc.active; photo: acc.avatar; }
                            }
                            VerticalLayout {
                                alignment: center;
                                spacing: 3px;
                                horizontal-stretch: 1;
                                Text { text: acc.username; color: Theme.text; font-size: 15px; font-weight: 600; overflow: elide; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    Badge {
                                        text: acc.kind;
                                        tint: acc.kind == "Microsoft" ? Theme.accent : Theme.text-muted;
                                    }
                                    if acc.active : Text { text: "● active"; color: Theme.success; font-size: 11px; vertical-alignment: center; }
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                PButton {
                                    text: acc.active ? "Active" : "Use";
                                    primary: !acc.active;
                                    enabled: !acc.active;
                                    clicked => { Logic.select-account(acc.uuid); }
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                PButton {
                                    text: "Remove";
                                    danger: true;
                                    clicked => {
                                        root.pending-uuid = acc.uuid;
                                        root.pending-name = acc.username;
                                        root.confirm-open = true;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ---- Remove confirmation ----
    if root.confirm-open : Dialog {
        dialog-width: 400px;
        closed => { root.confirm-open = false; }
        Text { text: "Remove account?"; color: Theme.text; font-size: 18px; font-weight: 700; }
        Text {
            text: "“" + root.pending-name + "” will be removed from the launcher.";
            color: Theme.text-muted; font-size: 13px; wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 10px;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { root.confirm-open = false; } }
            PButton {
                text: "Remove";
                danger: true;
                clicked => {
                    Logic.remove-account(root.pending-uuid);
                    root.confirm-open = false;
                }
            }
        }
    }

    // ---- Microsoft device-code dialog ----
    if Logic.ms-dialog-open : Dialog {
        dialog-width: 440px;
        closed => { Logic.cancel-microsoft(); }
        Text { text: "Sign in with Microsoft"; color: Theme.text; font-size: 18px; font-weight: 700; }
        HorizontalLayout {
            spacing: 8px;
            Text { text: "1. Open this page in your browser:"; color: Theme.text-muted; font-size: 13px; vertical-alignment: center; }
            PButton {
                text: "Open";
                height: 28px;
                clicked => { Logic.open-url(Logic.ms-verification-uri); }
            }
        }
        uri-touch := TouchArea {
            height: link-text.preferred-height;
            mouse-cursor: pointer;
            clicked => { Logic.open-url(Logic.ms-verification-uri); }
            link-text := Text {
                text: Logic.ms-verification-uri;
                color: uri-touch.has-hover ? Theme.accent-hover : Theme.accent;
                font-size: 14px;
                font-weight: 600;
            }
        }
        Text { text: "2. Enter this code:"; color: Theme.text-muted; font-size: 13px; }
        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                height: 48px;
                horizontal-stretch: 1;
                border-radius: Theme.radius-sm;
                background: Theme.surface-alt;
                Text {
                    text: Logic.ms-user-code;
                    color: Theme.text; font-size: 24px; font-weight: 700;
                    font-family: "monospace";
                }
            }
            PButton {
                text: "Copy";
                height: 48px;
                clicked => { Logic.copy-code(Logic.ms-user-code); }
            }
        }
        Text {
            text: Logic.ms-message;
            color: Logic.ms-active ? Theme.warning : Theme.text-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: end;
            padding-top: 8px;
            PButton { text: "Cancel"; clicked => { Logic.cancel-microsoft(); } }
        }
    }
}
