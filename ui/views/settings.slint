import { Theme, Logic } from "../globals.slint";
import { Card, PButton } from "../components.slint";
import { LineEdit, ComboBox, ScrollView } from "std-widgets.slint";

export component SettingsView inherits VerticalLayout {
    padding: 24px;
    spacing: 18px;

    ScrollView {
        VerticalLayout {
            spacing: 16px;

            Card {
                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;
                    Text { text: "Game"; color: Theme.text; font-size: 16px; font-weight: 700; }

                    Text { text: "Game directory"; color: Theme.text-muted; font-size: 12px; }
                    game-dir-edit := LineEdit { text: Logic.game-dir; }

                    Text { text: "Java path (\"java\" to use PATH / auto-install)"; color: Theme.text-muted; font-size: 12px; }
                    java-edit := LineEdit { text: Logic.java-path; }

                    Text { text: "JVM arguments (space separated)"; color: Theme.text-muted; font-size: 12px; }
                    jvm-edit := LineEdit { text: Logic.jvm-args; }

                    HorizontalLayout {
                        alignment: end;
                        PButton {
                            text: "Save";
                            primary: true;
                            clicked => {
                                Logic.save-settings(game-dir-edit.text, java-edit.text, jvm-edit.text);
                            }
                        }
                    }
                }
            }

            Card {
                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;
                    Text { text: "Java Runtimes"; color: Theme.text; font-size: 16px; font-weight: 700; }
                    Text {
                        text: "Manage the local JREs installed in the launcher's 'runtime' directory. Auto-detect will run the exact JRE version recommended by Mojang for each Minecraft version.";
                        color: Theme.text-dim; font-size: 11px; wrap: word-wrap;
                    }
                    VerticalLayout {
                        spacing: 8px;
                        for item in Logic.java-runtimes : Rectangle {
                            background: item.is-active ? Theme.surface-alt : transparent;
                            border-radius: Theme.radius-sm;
                            border-width: item.is-active ? 1px : 0px;
                            border-color: Theme.border;
                            
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 16px;
                                alignment: space-between;
                                
                                VerticalLayout {
                                    spacing: 4px;
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: item.name;
                                            color: item.is-active ? Theme.success : Theme.text;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }
                                        if item.is-active : Rectangle {
                                            background: Theme.success.with-alpha(0.2);
                                            border-radius: 4px;
                                            border-width: 1px;
                                            border-color: Theme.success;
                                            width: 58px;
                                            height: 18px;
                                            Text {
                                                text: "ACTIVE";
                                                color: Theme.success;
                                                font-size: 10px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                    Text {
                                        text: item.description;
                                        color: Theme.text-muted;
                                        font-size: 11px;
                                        wrap: word-wrap;
                                    }
                                }
                                
                                VerticalLayout {
                                    alignment: center;
                                    if item.status == "Active" : Text {
                                        text: "Active";
                                        color: Theme.success;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    if item.status == "Installed" : PButton {
                                        text: "Use";
                                        primary: false;
                                        clicked => { Logic.use-java-runtime(item.major); }
                                    }
                                    if item.status == "Not installed" : PButton {
                                        text: Logic.java-installing ? "Installing..." : "Download & use";
                                        primary: true;
                                        enabled: !Logic.java-installing;
                                        clicked => { Logic.install-java(item.major); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Card {
                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;
                    Text { text: "Appearance"; color: Theme.text; font-size: 16px; font-weight: 700; }
                    Text { text: "Theme"; color: Theme.text-muted; font-size: 12px; }
                    theme-combo := ComboBox {
                        model: Logic.themes;
                        current-value: Logic.active-theme;
                        selected(val) => { Logic.select-theme(val); }
                    }
                    Text {
                        text: "Drop *.json palettes in the launcher config 'themes' folder to add more.";
                        color: Theme.text-dim; font-size: 11px;
                    }
                }
            }
        }
    }
}
