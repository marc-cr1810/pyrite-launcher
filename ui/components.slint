// Reusable themed building blocks. All colors come from `Theme`.
import { Theme, Logic, Icons } from "globals.slint";
import { ScrollView } from "std-widgets.slint";

// A single Phosphor icon. Pass one of the `Icons.*` glyph constants.
export component Icon inherits Text {
    in property <string> icon;
    text: root.icon;
    font-family: Icons.font;
    horizontal-alignment: center;
    vertical-alignment: center;
    color: Theme.text;
}

// Push button with visual variants:
//   primary  - filled accent (main call to action)
//   danger   - quiet by default, turns red on hover (destructive actions)
//   ghost    - borderless, text-only (low-emphasis actions)
//   (default) - bordered secondary surface
export component PButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;     // optional leading Phosphor glyph (an Icons.* value)
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> ghost: false;
    in property <bool> enabled: true;
    callback clicked();

    // Shared by the label and the optional icon so they stay in lockstep.
    property <color> content-color: !enabled
        ? Theme.text-dim
        : primary ? Theme.accent-text
        : danger ? (touch.has-hover ? Theme.accent-text : Theme.error)
        : Theme.text;

    height: 38px;
    horizontal-stretch: 0;
    min-width: content.preferred-width + 32px;
    border-radius: Theme.radius-sm;
    background: !enabled
        ? (ghost ? transparent : Theme.surface-alt)
        : primary
            ? (touch.has-hover ? Theme.accent-hover : Theme.accent)
            : danger
                ? (touch.has-hover ? Theme.error : transparent)
                : ghost
                    ? (touch.has-hover ? Theme.surface : transparent)
                    : (touch.has-hover ? Theme.surface-hover : Theme.surface-alt);
    border-width: (primary || ghost) ? 0px : 1px;
    border-color: danger ? (touch.has-hover ? Theme.error : Theme.border) : Theme.border;
    animate background, border-color { duration: 120ms; }

    content := HorizontalLayout {
        alignment: center;
        spacing: 8px;
        if root.icon != "" : Icon {
            icon: root.icon;
            color: root.content-color;
            font-size: 17px;
        }
        Text {
            text: root.text;
            color: root.content-color;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Subtle elevated card surface.
export component Card inherits Rectangle {
    in property <length> elevation: 8px;
    background: Theme.surface;
    border-radius: Theme.radius;
    border-width: 1px;
    border-color: Theme.border;
    drop-shadow-color: #00000040;
    drop-shadow-blur: root.elevation;
    drop-shadow-offset-y: root.elevation / 4;
}

// Progress bar. Determinate by default; set `indeterminate` for an animated
// sweeping segment when there is no measurable progress (resolving, verifying…).
export component PProgress inherits Rectangle {
    in property <float> value: 0.0; // 0..1
    in property <bool> indeterminate: false;
    height: 8px;
    border-radius: 4px;
    background: Theme.surface-alt;
    clip: true;

    // Determinate fill.
    Rectangle {
        x: 0;
        visible: !root.indeterminate;
        width: parent.width * clamp(root.value, 0.0, 1.0);
        height: parent.height;
        border-radius: 4px;
        background: Theme.accent;
        animate width { duration: 120ms; }
    }

    // Indeterminate sweep — a segment that loops left→right while active.
    // Driven by animation-tick() (gated on `indeterminate` so it doesn't keep
    // the window repainting when idle) instead of an `animate` block, which
    // would only run once because the target value is constant.
    sweep := Rectangle {
        visible: root.indeterminate;
        property <duration> elapsed: root.indeterminate ? animation-tick() : 0ms;
        property <float> phase: Math.mod(self.elapsed / 1ms, 1400) / 1400;
        width: parent.width * 0.35;
        height: parent.height;
        border-radius: 4px;
        background: Theme.accent;
        x: -self.width + (parent.width + self.width) * self.phase;
    }
}

// Section heading.
export component PHeading inherits Text {
    color: Theme.text;
    font-size: 22px;
    font-weight: 700;
}

// Round monogram avatar: a colored disc with an initial. Avoids any network
// fetch while still giving accounts/instances a recognizable identity.
export component Avatar inherits Rectangle {
    in property <string> initial;
    in property <color> tint: Theme.accent;
    in property <length> size: 40px;
    in property <bool> selected: false;
    in property <image> photo;   // optional; overlays the monogram once loaded
    // When the `initial` is a Phosphor icon glyph (a built-in instance icon)
    // rather than a letter, render it in the icon font instead of the UI font.
    in property <bool> icon-font: false;
    width: root.size;
    height: root.size;
    // Rounded square (player heads are square), not a circle.
    border-radius: root.size * 0.18;
    background: root.tint.with-alpha(0.18);
    border-width: root.selected ? 2px : 0px;
    border-color: root.tint;
    clip: true;
    // Monogram fallback (shown until/unless a photo is present).
    Text {
        text: root.initial;
        color: root.tint;
        font-family: root.icon-font ? Icons.font : "";
        font-size: root.size * (root.icon-font ? 0.55 : 0.42);
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    // Player head, drawn on top when available.
    if root.photo.width > 0 : Image {
        width: 100%;
        height: 100%;
        source: root.photo;
        image-fit: cover;
        image-rendering: pixelated;
    }
}

// Small colored pill, e.g. a mod-loader label.
export component Badge inherits Rectangle {
    in property <string> text;
    in property <color> tint: Theme.accent;
    horizontal-stretch: 0;
    height: 20px;
    min-width: label.preferred-width + 16px;
    border-radius: 10px;
    background: root.tint.with-alpha(0.16);
    label := Text {
        x: 8px;
        text: root.text;
        color: root.tint;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
    }
}

// Mod-loader pill, tinted consistently across views.
export component LoaderBadge inherits Badge {
    in property <string> loader;
    text: root.loader;
    tint: root.loader == "Fabric" ? Theme.warning
        : root.loader == "Forge" ? Theme.accent
        : root.loader == "NeoForge" ? #ff9e64
        : Theme.text-muted;
}

// Centered empty-state block with an icon, message and optional call-to-action.
export component EmptyState inherits VerticalLayout {
    in property <string> icon;
    in property <string> title;
    in property <string> subtitle;
    in property <string> action-text;
    callback action();
    alignment: center;
    spacing: 8px;
    HorizontalLayout {
        alignment: center;
        Text { text: root.icon; font-family: Icons.font; font-size: 40px; color: Theme.text-dim; }
    }
    Text {
        text: root.title;
        color: Theme.text-muted;
        font-size: 15px;
        font-weight: 600;
        horizontal-alignment: center;
    }
    if root.subtitle != "" : Text {
        text: root.subtitle;
        color: Theme.text-dim;
        font-size: 12px;
        horizontal-alignment: center;
    }
    if root.action-text != "" : HorizontalLayout {
        alignment: center;
        padding-top: 6px;
        PButton { text: root.action-text; primary: true; clicked => { root.action(); } }
    }
}

// Instance icon picker: a live preview, a grid of built-in glyph icons, plus
// "Monogram" (none) and "Choose file…" (custom PNG). Operates on the shared
// `Logic.pending-icon-*` state, so only one picker should be visible at a time.
export component IconPicker inherits VerticalLayout {
    // Monogram fallback shown when no icon is chosen.
    in property <string> derived-initial;
    in property <color> derived-color;
    // Empty image used as the preview's "no photo" fallback.
    property <image> no-image;
    spacing: 8px;

    Text { text: "Icon"; color: Theme.text-muted; font-size: 12px; }

    HorizontalLayout {
        spacing: 14px;

        // Live preview.
        VerticalLayout {
            alignment: start;
            Avatar {
                initial: Logic.pending-icon-glyph != "" ? Logic.pending-icon-glyph : root.derived-initial;
                icon-font: Logic.pending-icon-glyph != "";
                tint: root.derived-color;
                size: 56px;
                photo: Logic.pending-icon-id == "custom" ? Logic.pending-icon-image : root.no-image;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 8px;

            // Built-in glyph grid (6 per row).
            GridLayout {
                spacing: 6px;
                for opt[i] in Logic.icon-options : Rectangle {
                    row: floor(i / 6);
                    col: mod(i, 6);
                    width: 34px;
                    height: 34px;
                    border-radius: Theme.radius-sm;
                    background: Logic.pending-icon-id == opt.id
                        ? Theme.surface-alt
                        : (swatch.has-hover ? Theme.surface-hover : transparent);
                    border-width: 1px;
                    border-color: Logic.pending-icon-id == opt.id ? Theme.accent : Theme.border;
                    animate background, border-color { duration: 100ms; }
                    Text {
                        text: opt.glyph;
                        color: Theme.text;
                        font-family: Icons.font;
                        font-size: 19px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    swatch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            Logic.pending-icon-id = opt.id;
                            Logic.pending-icon-glyph = opt.glyph;
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                PButton {
                    text: "Monogram";
                    clicked => {
                        Logic.pending-icon-id = "";
                        Logic.pending-icon-glyph = "";
                    }
                }
                PButton {
                    text: "Choose file…";
                    clicked => { Logic.pick-custom-icon(); }
                }
            }
        }
    }
}

// Modal dialog: dims the background, swallows clicks behind it, closes on
// backdrop click or Escape, and floats a shadowed card sized to its content.
export component Dialog inherits Rectangle {
    in property <length> dialog-width: 460px;
    callback closed();
    width: 100%;
    height: 100%;
    background: #00000099;

    // Backdrop click closes.
    backdrop := TouchArea {
        clicked => { root.closed(); }
    }

    // Escape closes. Grabs focus while the dialog is shown.
    key-handler := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.closed();
                return accept;
            }
            return reject;
        }
    }
    init => { key-handler.focus(); }

    // Center the card and let it size to its content (otherwise it fills the
    // whole window and the field layout spreads out to fill the height).
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Card {
                elevation: 24px;
                width: root.dialog-width;
                // Click inside the card must not fall through to the backdrop.
                TouchArea {}
                VerticalLayout {
                    padding: 24px;
                    spacing: 12px;
                    @children
                }
            }
        }
    }
}
